# Mapbox GL JS access token (required for map rendering)
MAPBOX_ACCESS_TOKEN=pk.your_token_here

# ETL pipeline manifest URL — points to CNT's staging server, which serves the data.json
# manifest listing all source files. The data files themselves are publicly accessible on S3.
# No AWS credentials are needed; all downloads use plain HTTPS.
ETL_MANIFEST_URL=https://apps.cnt.org/water-data-tool-staging/data/data.json
