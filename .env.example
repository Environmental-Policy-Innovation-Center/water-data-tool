# Mapbox GL JS access token (required for map rendering)
MAPBOX_ACCESS_TOKEN=pk.your_token_here

# Local database URL override — only needed if your Docker container runs on a
# non-default port (e.g. port 5433 to avoid conflict with a local Homebrew PostgreSQL).
# Create a docker-compose.override.yml to remap the port, then set this accordingly.
# DATABASE_URL=postgis://postgres:postgres@localhost:5433/water_data_tool_development

# AWS credentials (only needed for ETL pipeline — not required for local dev with seed data)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
