<%# Shared by in-app map load and direct URL visit. Layout: false (fragment) vs layouts/report (full page). %>
<% content_for :title, "#{@pws.pws_name} — Utility Report" unless turbo_frame_request? %>

<%# Turbo Frame wrapper required for map overlay; also present on standalone page (Turbo extracts or renders as-is). %>
<turbo-frame id="report-body">
  <%= render "report_content", pws: @pws %>
</turbo-frame>
