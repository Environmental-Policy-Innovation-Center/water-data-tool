<%= render UI::DetailSectionComponent.new(
  title: "Overview",
  rows: [
    {label: "Population Served", value: number_with_delimiter(pws.population_served_count)},
    {label: "Service Connections", value: number_with_delimiter(pws.service_connections_count)},
    {label: "Water Source", value: pws.gw_sw_code},
    {label: "Owner Type", value: pws.owner_type},
    {label: "Primacy Type", value: pws.primacy_type},
    {label: "Service Area Type", value: pws.service_area_type},
    {label: "Area (sq mi)", value: pws.area_sq_miles ? number_with_precision(pws.area_sq_miles, precision: 2) : "N/A"},
    {label: "Counties", value: pws.counties.presence || "N/A"},
    {label: "Open Health Violations", value: pws.open_health_viol}
  ]
) %>
