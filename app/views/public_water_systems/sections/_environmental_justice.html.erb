<%= render UI::DetailSectionComponent.new(
  title: "Environmental Justice",
  data_available: ej.present?,
  rows: ej ? [
    {label: "CEJST Disadvantaged", value: ej.cejst_disadvantaged_pct ? number_to_percentage(ej.cejst_disadvantaged_pct, precision: 1) : "N/A"},
    {label: "CEJST Lead Paint", value: ej.cejst_lead_paint_indicator || "N/A"},
    {label: "CEJST Low Life Expectancy", value: ej.cejst_low_life_expectancy_pctl || "N/A"},
    {label: "SVI Overall Percentile", value: ej.svi_overall_pctl || "N/A"},
    {label: "EJScreen Drinking Water", value: ej.ejscreen_drinking_water || "N/A"},
    {label: "EJScreen Disability Rate", value: ej.ejscreen_disability_rate || "N/A"},
    {label: "CVI Overall Score", value: ej.cvi_overall_score || "N/A"},
    {label: "CVI Redlining", value: ej.cvi_redlining || "N/A"},
    {label: "CVI Life Expectancy", value: ej.cvi_life_expectancy || "N/A"},
    {label: "CVI Cancer Risk", value: ej.cvi_cancer_risk || "N/A"}
  ] : []
) %>
