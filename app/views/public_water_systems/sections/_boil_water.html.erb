<%
  boil_rows = boil_water ? [
    {label: "Total Notices", value: boil_water.total_notices},
    {label: "Date Range", value: boil_water.date_range_display || "N/A"},
    {label: "First Advisory", value: boil_water.first_advisory_date || "N/A"},
    {label: "Last Advisory", value: boil_water.last_advisory_date || "N/A"}
  ] : []
  if boil_water&.state_reporting_year_min && boil_water&.state_reporting_year_max
    boil_rows << {label: "State Reporting Years", value: "#{boil_water.state_reporting_year_min}–#{boil_water.state_reporting_year_max}"}
  end
%>
<%= render UI::DetailSectionComponent.new(
  title: "Boil Water Notices",
  data_available: boil_water.present?,
  rows: boil_rows
) %>
