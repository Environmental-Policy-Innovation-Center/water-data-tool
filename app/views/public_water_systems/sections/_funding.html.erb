<%= render UI::DetailSectionComponent.new(
  title: "Funding",
  data_available: funding.present?,
  rows: funding ? [
    {label: "Times Funded", value: funding.times_funded},
    {label: "Total SRF Assistance", value: funding.total_srf_assistance ? number_to_currency(funding.total_srf_assistance, precision: 0) : "N/A"},
    {label: "Median SRF Assistance", value: funding.median_srf_assistance ? number_to_currency(funding.median_srf_assistance, precision: 0) : "N/A"},
    {label: "Total Principal Forgiveness", value: funding.total_principal_forgiveness ? number_to_currency(funding.total_principal_forgiveness, precision: 0) : "N/A"}
  ] : []
) %>
