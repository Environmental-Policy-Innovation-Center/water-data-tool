<%= render UI::DetailSectionComponent.new(
  title: "10-Year Trends (2011–2021)",
  data_available: trends.present?,
  rows: trends ? [
    {label: "Population Change", value: trend_value(trends.population_pct_change)},
    {label: "Median Income Change", value: trend_value(trends.mhi_pct_change)},
    {label: "Households Change", value: trend_value(trends.households_pct_change)},
    {label: "Poverty Change", value: trend_value(trends.poverty_pct_change)},
    {label: "Unemployment Change", value: trend_value(trends.unemployment_pct_change)},
    {label: "Race/Ethnicity Change", value: trend_value(trends.poc_pct_change)}
  ] : []
) %>
