<div class="detail-section">
  <h3>Violations</h3>
  <% if violations.nil? %>
    <p class="detail-na">Data not available</p>
  <% else %>
    <table class="detail-table">
      <tr><th></th><th>5-Year</th><th>10-Year</th></tr>
      <tr><td>Health</td><td><%= violations.health_violations_5yr %></td><td><%= violations.health_violations_10yr %></td></tr>
      <tr><td>Groundwater Rule</td><td><%= violations.groundwater_rule_5yr %></td><td><%= violations.groundwater_rule_10yr %></td></tr>
      <tr><td>Surface Water Treatment</td><td><%= violations.surface_water_treatment_5yr %></td><td><%= violations.surface_water_treatment_10yr %></td></tr>
      <tr><td>Lead & Copper</td><td><%= violations.lead_and_copper_5yr %></td><td><%= violations.lead_and_copper_10yr %></td></tr>
      <tr><td>Radionuclides</td><td><%= violations.radionuclides_5yr %></td><td><%= violations.radionuclides_10yr %></td></tr>
      <tr><td>Inorganic Chemicals</td><td><%= violations.inorganic_chemicals_5yr %></td><td><%= violations.inorganic_chemicals_10yr %></td></tr>
      <tr><td>Synthetic Organic</td><td><%= violations.synthetic_organic_chemicals_5yr %></td><td><%= violations.synthetic_organic_chemicals_10yr %></td></tr>
      <tr><td>Volatile Organic</td><td><%= violations.volatile_organic_chemicals_5yr %></td><td><%= violations.volatile_organic_chemicals_10yr %></td></tr>
      <tr><td>Total Coliform</td><td><%= violations.total_coliform_5yr %></td><td><%= violations.total_coliform_10yr %></td></tr>
      <tr><td>Stage 1 Disinfectants</td><td><%= violations.stage_1_disinfectants_5yr %></td><td><%= violations.stage_1_disinfectants_10yr %></td></tr>
      <tr><td>Stage 2 Disinfectants</td><td><%= violations.stage_2_disinfectants_5yr %></td><td><%= violations.stage_2_disinfectants_10yr %></td></tr>
      <tr><td>Paperwork</td><td><%= violations.paperwork_violations_5yr %></td><td><%= violations.paperwork_violations_10yr %></td></tr>
      <tr class="detail-table-total"><td>Total</td><td><%= violations.total_violations_5yr %></td><td><%= violations.total_violations_10yr %></td></tr>
    </table>
    <% if violations.violations_all_years %>
      <p class="detail-footnote">All years total: <%= violations.violations_all_years %></p>
    <% end %>
  <% end %>
</div>
