<%= render UI::DetailSectionComponent.new(
  title: "Watershed Hazards",
  data_available: hazard.present?,
  rows: hazard ? [
    {label: "Facilities", value: hazard.num_facilities},
    {label: "NPDES Permits", value: hazard.npdes_permits},
    {label: "Effluent Violations", value: hazard.permit_effluent_violations},
    {label: "Underground Storage Tanks", value: hazard.open_underground_storage_tanks},
    {label: "Risk Management Facilities", value: hazard.risk_management_plan_facilities},
    {label: "Impaired Streams (303d)", value: hazard.impaired_streams_303d}
  ] : []
) %>
