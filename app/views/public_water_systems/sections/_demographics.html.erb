<%= render UI::DetailSectionComponent.new(
  title: "Demographics",
  data_available: demographic.present?,
  rows: demographic ? [
    {label: "Total Population", value: number_with_delimiter(demographic.total_population)},
    {label: "Population Density", value: "#{number_with_precision(demographic.population_density, precision: 1)} / sq mi"},
    {label: "Median Household Income", value: demographic.median_household_income ? number_to_currency(demographic.median_household_income, precision: 0) : "N/A"},
    {label: "Poverty Rate", value: demographic.poverty_rate ? number_to_percentage(demographic.poverty_rate, precision: 1) : "N/A"},
    {label: "Unemployment Rate", value: demographic.unemployment_rate ? number_to_percentage(demographic.unemployment_rate, precision: 1) : "N/A"},
    {label: "No Health Insurance", value: demographic.no_health_insurance_rate ? number_to_percentage(demographic.no_health_insurance_rate, precision: 1) : "N/A"},
    {label: "Bachelor's Degree+", value: demographic.bachelors_degree_rate ? number_to_percentage(demographic.bachelors_degree_rate, precision: 1) : "N/A"},
    {label: "Under 5", value: demographic.age_under_5_rate ? number_to_percentage(demographic.age_under_5_rate, precision: 1) : "N/A"},
    {label: "Over 61", value: demographic.age_over_61_rate ? number_to_percentage(demographic.age_over_61_rate, precision: 1) : "N/A"},
    {label: "People of Color", value: demographic.poc_rate ? number_to_percentage(demographic.poc_rate, precision: 1) : "N/A"},
    {label: "Renter-Occupied", value: demographic.renter_rate ? number_to_percentage(demographic.renter_rate, precision: 1) : "N/A"},
    {label: "Most Common Rate Tier", value: HomeHelper::RATE_TIER_LABELS.fetch(demographic.most_common_rate_tier, "N/A")}
  ] : []
) %>
