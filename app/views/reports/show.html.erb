<turbo-frame id="report-body">
  <div class="report-content">
    <h2 data-report-field="name"><%= @pws.pws_name %></h2>
    <p><span data-report-field="id"><%= @pws.pwsid %></span> &mdash; <span data-report-field="state"><%= @pws.stusps %></span></p>

    <%= render "public_water_systems/sections/overview", pws: @pws %>
    <%= render "public_water_systems/sections/demographics", demographic: @pws.demographic %>
    <%= render "public_water_systems/sections/environmental_justice", ej: @pws.environmental_justice %>
    <%= render "public_water_systems/sections/violations", violations: @pws.violations_summary %>
    <%= render "public_water_systems/sections/funding", funding: @pws.funding_summary %>
    <%= render "public_water_systems/sections/watershed_hazards", hazard: @pws.watershed_hazard %>
    <%= render "public_water_systems/sections/boil_water", boil_water: @pws.boil_water_summary %>
    <%= render "public_water_systems/sections/trends", trends: @pws.trend_datum %>
  </div>
</turbo-frame>
