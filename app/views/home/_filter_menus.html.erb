<%# Filter dropdown menus — rendered inside #container-map, positioned absolutely %>
<%# Full filter wiring happens in M6 (depends on M3 PWS API). These are structural shells. %>

<!-- 1. SOURCE -->
<%= render UI::FilterMenuPanelComponent.new(menu_id: 1) do %>
  <div id="container-menu-1-items">
    <%= render Filters::CategoryComponent.new(label: "Primary type", tooltip_text: filter_tooltips["primary_type"]) do %>
      <ul class="my-[6px] mb-[10px] mx-0 list-none px-1">
        <li class="<%= filter_row_classes %>"><input type="radio" name="water-source" id="ws-both" data-default <%= checked_if filter_option_checked?("gw_sw_code", nil, default: true) %>><label for="ws-both">Both ground and surface</label></li>
        <li class="<%= filter_row_classes %>"><input type="radio" name="water-source" id="ws-ground" <%= checked_if filter_option_checked?("gw_sw_code", "Groundwater") %>><label for="ws-ground">Ground only</label></li>
        <li class="<%= filter_row_classes %>"><input type="radio" name="water-source" id="ws-surface" <%= checked_if filter_option_checked?("gw_sw_code", "Surface Water") %>><label for="ws-surface">Surface only</label></li>
      </ul>
    <% end %>
    <%= render Filters::CategoryComponent.new(label: "Place") do %>
      <div data-controller="place-autocomplete"
           data-action="focusout->place-autocomplete#focusOut"
           class="relative mb-2.5">
        <input type="text" class="js-place-search w-full bg-white px-2.5 py-1.5 border border-[#ccc] rounded text-[0.95em] transition-colors duration-200 data-[pulse]:bg-neutral-100 <%= focus_ring_classes %>"
               placeholder="Search for a city or town..."
               role="combobox"
               aria-autocomplete="list"
               aria-expanded="false"
               aria-controls="place-search-results"
               value="<%= place_search_value %>"
               data-place-autocomplete-target="input"
               data-action="input->place-autocomplete#search keydown->place-autocomplete#keydown"
               autocomplete="off">
        <input type="hidden" id="place-geoid" data-place-autocomplete-target="geoid" value="<%= filter_state["place_geoid"] %>">
        <ul id="place-search-results"
            role="listbox"
            aria-label="Place search results"
            data-place-autocomplete-target="results"
            class="hidden list-none m-0 p-0 absolute inset-x-0 top-full z-[1000] max-h-48 overflow-y-auto bg-white border border-[#ccc] rounded shadow-[0_2px_6px_rgba(0,0,0,0.15)]"></ul>
        <template data-place-autocomplete-target="optionTemplate">
          <li>
            <button type="button"
                    role="option"
                    tabindex="-1"
                    aria-selected="false"
                    class="block w-full cursor-pointer border-0 bg-transparent px-2.5 py-1.5 text-left text-[0.95em] text-[#333] hover:bg-neutral-100 aria-selected:bg-neutral-100 <%= focus_ring_classes %>"
                    data-action="click->place-autocomplete#select"></button>
          </li>
        </template>
      </div>
    <% end %>
    <%= render Filters::CategoryComponent.new(label: "Protection") do %>
      <ul class="my-[6px] mb-[10px] mx-0 list-none px-1">
        <li class="<%= filter_row_classes %>">
          <input type="checkbox" class="toggle" id="has-source-water-protection" <%= checked_if filter_active?("has_source_protection") %>>
          <label for="has-source-water-protection">Has source protection</label>
          <%= tooltip_icon(filter_tooltips["source_protection"]) %>
        </li>
      </ul>
    <% end %>
  </div>
<% end %>

<!-- 2. ATTRIBUTES -->
<%= render UI::FilterMenuPanelComponent.new(menu_id: 2) do %>
  <div id="container-menu-2-items">
    <%= render Filters::CategoryComponent.new(label: "Ownership") do %>
      <ul class="my-[6px] mb-[10px] mx-0 list-none px-1">
        <li class="<%= filter_row_classes %>">
          <%= render UI::CircleToggleComponent.new(
                id: "type-deselect-all",
                checked: !filter_active?("owner_type"),
                label: filter_active?("owner_type") ? "Select all" : "Deselect all",
                data_action: "change->filter#toggleSelectAll",
                input_classes: "toggle select-all default-checked"
              ) %>
        </li>
        <li class="<%= filter_row_classes %>"><input type="checkbox" class="toggle default-checked checkbox-type" id="type-federal-government" data-action="change->filter#syncSelectAll" <%= checked_if filter_option_checked?("owner_type", "Federal", default: true) %>><label for="type-federal-government">Federal</label></li>
        <li class="<%= filter_row_classes %>"><input type="checkbox" class="toggle default-checked checkbox-type" id="type-state-government" data-action="change->filter#syncSelectAll" <%= checked_if filter_option_checked?("owner_type", "State", default: true) %>><label for="type-state-government">State</label></li>
        <li class="<%= filter_row_classes %>"><input type="checkbox" class="toggle default-checked checkbox-type" id="type-local-government" data-action="change->filter#syncSelectAll" <%= checked_if filter_option_checked?("owner_type", "Local", default: true) %>><label for="type-local-government">Local</label></li>
        <li class="<%= filter_row_classes %>"><input type="checkbox" class="toggle default-checked checkbox-type" id="type-native-american" data-action="change->filter#syncSelectAll" <%= checked_if filter_option_checked?("owner_type", "Native American", default: true) %>><label for="type-native-american">Tribal</label></li>
        <li class="<%= filter_row_classes %>"><input type="checkbox" class="toggle default-checked checkbox-type" id="type-private" data-action="change->filter#syncSelectAll" <%= checked_if filter_option_checked?("owner_type", "Private", default: true) %>><label for="type-private">Private</label></li>
        <li class="<%= filter_row_classes %>"><input type="checkbox" class="toggle default-checked checkbox-type" id="type-public-private" data-action="change->filter#syncSelectAll" <%= checked_if filter_option_checked?("owner_type", "Public/Private", default: true) %>><label for="type-public-private">Public/Private partnership</label></li>
      </ul>
    <% end %>
    <%= render Filters::CategoryComponent.new(label: "Authority") do %>
      <ul class="my-[6px] mb-[10px] mx-0 list-none px-1">
        <li class="<%= filter_row_classes %>"><input type="checkbox" class="toggle default-checked" id="primacy-type-state" <%= checked_if filter_option_checked?("primacy_type", "State", default: true) %>><label for="primacy-type-state">State</label></li>
        <li class="<%= filter_row_classes %>"><input type="checkbox" class="toggle default-checked" id="primacy-type-tribal" <%= checked_if filter_option_checked?("primacy_type", "Tribal", default: true) %>><label for="primacy-type-tribal">Tribal</label></li>
        <li class="<%= filter_row_classes %>"><input type="checkbox" class="toggle default-checked" id="primacy-type-territory" <%= checked_if filter_option_checked?("primacy_type", "Territory", default: true) %>><label for="primacy-type-territory">Territory</label></li>
      </ul>
    <% end %>
    <%= render Filters::CategoryComponent.new(label: "Distribution") do %>
      <ul class="my-[6px] mb-[10px] mx-0 list-none px-1">
        <li class="<%= filter_row_classes %>">
          <input type="checkbox" class="toggle" id="is-wholesaler" <%= checked_if filter_active?("is_wholesaler") %>>
          <label for="is-wholesaler">Wholesaler</label>
          <%= tooltip_icon(filter_tooltips["wholesaler"]) %>
        </li>
      </ul>
    <% end %>
    <%= render Filters::CategoryComponent.new(label: "Facility type") do %>
      <ul class="my-[6px] mb-[10px] mx-0 list-none px-1">
        <li class="<%= filter_row_classes %>"><input type="checkbox" class="toggle" id="is-school-or-daycare" <%= checked_if filter_active?("is_school_or_daycare") %>><label for="is-school-or-daycare">School or daycare</label></li>
      </ul>
    <% end %>
  </div>
<% end %>

<!-- 3. BOUNDARIES -->
<%= render UI::FilterMenuPanelComponent.new(menu_id: 3) do %>
  <div id="container-menu-3-items">
    <%= render Filters::CategoryComponent.new(label: "Type", tooltip_text: filter_tooltips["boundary_type"]) do %>
      <ul class="my-[6px] mb-[10px] mx-0 list-none px-1">
        <li class="<%= filter_row_classes %>"><input type="radio" name="boundary-type" id="bt-both" data-default <%= checked_if filter_option_checked?("symbology_field", nil, default: true) %>><label for="bt-both">Both modeled and system sourced</label></li>
        <li class="<%= filter_row_classes %>"><input type="radio" name="boundary-type" id="bt-modeled" <%= checked_if filter_option_checked?("symbology_field", "Modeled") %>><label for="bt-modeled">Modeled only</label></li>
        <li class="<%= filter_row_classes %>"><input type="radio" name="boundary-type" id="bt-system" <%= checked_if filter_option_checked?("symbology_field", "System Sourced") %>><label for="bt-system">System sourced only</label></li>
      </ul>
    <% end %>
    <%= render Filters::CategoryComponent.new(label: "Size") do %>
      <p class="my-2.5 mx-0 px-[15px] py-1.5 text-sm font-bold text-neutral-700">Area in square miles</p>
      <div class="mb-5">
        <select id="area-min" aria-label="Minimum area (sq mi)" class="toggle-select min-select left bg-white border border-neutral-400 rounded-md py-2.5 px-[18px] w-[40%] ml-[15px] text-[.9em]">
          <%= range_select_options(steps: HomeHelper::AREA_STEPS, param: "area", bound: :min) %>
        </select>
        <select id="area-max" aria-label="Maximum area (sq mi)" class="toggle-select max-select right bg-white border border-neutral-400 rounded-md py-2.5 px-[18px] w-[40%] ml-[15px] text-[.9em]">
          <%= range_select_options(steps: HomeHelper::AREA_STEPS, param: "area", bound: :max) %>
        </select>
      </div>
    <% end %>
  </div>
<% end %>

<!-- 4. COMPLIANCE -->
<%= render UI::FilterMenuPanelComponent.new(menu_id: 4, width_class: "w-[390px]") do %>
  <div id="container-menu-4-items">
    <%= render Filters::CategoryComponent.new(label: "Violations", tooltip_text: filter_tooltips["violations"]) do %>
      <ul class="my-[6px] mb-[10px] mx-0 list-none px-1">
        <li class="<%= filter_row_classes %>"><input type="checkbox" class="toggle" id="compliance-open-violations" <%= checked_if filter_active?("has_open_violations") %>><label for="compliance-open-violations">Open violations</label></li>
        <% health_5yr = subcat_parent_state(:health_5yr) %>
        <li class="<%= filter_row_classes %>">
          <input type="checkbox" class="toggle" id="viols-health-5yrs"
                 data-action="change->filter#toggleSubcat"
                 data-panel-id="subcat-health-5yr" <%= checked_if health_5yr[:all] %>>
          <label for="viols-health-5yrs">Health violations in the last 5 years</label>
          <button type="button" class="<%= filter_info_button_classes %>"
                  data-action="click->filter#toggleSubcatPanel"
                  data-panel-id="subcat-health-5yr"
                  aria-expanded="<%= health_5yr[:any] %>"
                  aria-controls="subcat-health-5yr">
            <%= icon("arrow-down", classes: collapse_toggle_icon_classes(expanded: health_5yr[:any])) %>
          </button>
          <div id="subcat-health-5yr" class="<%= health_5yr[:any] ? "pl-2 pb-1" : "hidden pl-2 pb-1" %>" data-subcat-panel
               data-action="change->filter#syncParentFromSubcat">
          <ul class="mt-1 list-none px-1">
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-groundwater-5yr", panel_id: "slider-groundwater-5yr",
                  label: "Ground water rule", tooltip_text: filter_tooltips["groundwater_rule"],
                  field: "groundwater_rule_5yr", min_input_id: "min-groundwater-5yr", max_input_id: "max-groundwater-5yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-surface-water-5yr", panel_id: "slider-surface-water-5yr",
                  label: "Surface water treatment rules", tooltip_text: filter_tooltips["surface_water_treatment"],
                  field: "surface_water_treatment_5yr", min_input_id: "min-surface-water-5yr", max_input_id: "max-surface-water-5yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-lead-copper-5yr", panel_id: "slider-lead-copper-5yr",
                  label: "Lead & copper", tooltip_text: filter_tooltips["lead_and_copper"],
                  field: "lead_and_copper_5yr", min_input_id: "min-lead-copper-5yr", max_input_id: "max-lead-copper-5yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-radionuclides-5yr", panel_id: "slider-radionuc-5yr",
                  label: "Radionuclides", tooltip_text: filter_tooltips["radionuclides"],
                  field: "radionuclides_5yr", min_input_id: "min-radionuc-5yr", max_input_id: "max-radionuc-5yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-inorganic-5yr", panel_id: "slider-inorganic-5yr",
                  label: "Inorganic chemicals", tooltip_text: filter_tooltips["inorganic_chemicals"],
                  field: "inorganic_chemicals_5yr", min_input_id: "min-inorganic-5yr", max_input_id: "max-inorganic-5yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-synthetic-5yr", panel_id: "slider-soc-5yr",
                  label: "Synthetic organic chemicals", tooltip_text: filter_tooltips["synthetic_organic_chemicals"],
                  field: "synthetic_organic_chemicals_5yr", min_input_id: "min-soc-5yr", max_input_id: "max-soc-5yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-vocs-5yr", panel_id: "slider-voc-5yr",
                  label: "Volatile organic chemicals", tooltip_text: filter_tooltips["volatile_organic_chemicals"],
                  field: "volatile_organic_chemicals_5yr", min_input_id: "min-voc-5yr", max_input_id: "max-voc-5yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-coliform-5yr", panel_id: "slider-coliform-5yr",
                  label: "Coliform", tooltip_text: filter_tooltips["total_coliform"],
                  field: "total_coliform_5yr", min_input_id: "min-coliform-5yr", max_input_id: "max-coliform-5yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-stage-1-disinfectants-5yr", panel_id: "slider-stage1-dis-5yr",
                  label: "Stage 1 disinfectants", tooltip_text: filter_tooltips["stage_1_disinfectants"],
                  field: "stage_1_disinfectants_5yr", min_input_id: "min-stage1-dis-5yr", max_input_id: "max-stage1-dis-5yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-stage-2-disinfectants-5yr", panel_id: "slider-stage2-dis-5yr",
                  label: "Stage 2 disinfectants", tooltip_text: filter_tooltips["stage_2_disinfectants"],
                  field: "stage_2_disinfectants_5yr", min_input_id: "min-stage2-dis-5yr", max_input_id: "max-stage2-dis-5yr", nested: true) %>
          </ul>
          </div>
        </li>
        <% health_10yr = subcat_parent_state(:health_10yr) %>
        <li class="<%= filter_row_classes %>">
          <input type="checkbox" class="toggle" id="viols-health"
                 data-action="change->filter#toggleSubcat"
                 data-panel-id="subcat-health-10yr" <%= checked_if health_10yr[:all] %>>
          <label for="viols-health">Health violations in the last 10 years</label>
          <button type="button" class="<%= filter_info_button_classes %>"
                  data-action="click->filter#toggleSubcatPanel"
                  data-panel-id="subcat-health-10yr"
                  aria-expanded="<%= health_10yr[:any] %>"
                  aria-controls="subcat-health-10yr">
            <%= icon("arrow-down", classes: collapse_toggle_icon_classes(expanded: health_10yr[:any])) %>
          </button>
          <div id="subcat-health-10yr" class="<%= health_10yr[:any] ? "pl-2 pb-1" : "hidden pl-2 pb-1" %>" data-subcat-panel
               data-action="change->filter#syncParentFromSubcat">
          <ul class="mt-1 list-none px-1">
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-groundwater-10yr", panel_id: "slider-groundwater-10yr",
                  label: "Ground water rule", tooltip_text: filter_tooltips["groundwater_rule"],
                  field: "groundwater_rule_10yr", min_input_id: "min-groundwater-10yr", max_input_id: "max-groundwater-10yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-surface-water-10yr", panel_id: "slider-surface-water-10yr",
                  label: "Surface water treatment rules", tooltip_text: filter_tooltips["surface_water_treatment"],
                  field: "surface_water_treatment_10yr", min_input_id: "min-surface-water-10yr", max_input_id: "max-surface-water-10yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-lead-copper-10yr", panel_id: "slider-lead-copper-10yr",
                  label: "Lead & copper", tooltip_text: filter_tooltips["lead_and_copper"],
                  field: "lead_and_copper_10yr", min_input_id: "min-lead-copper-10yr", max_input_id: "max-lead-copper-10yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-radionuclides-10yr", panel_id: "slider-radionuc-10yr",
                  label: "Radionuclides", tooltip_text: filter_tooltips["radionuclides"],
                  field: "radionuclides_10yr", min_input_id: "min-radionuc-10yr", max_input_id: "max-radionuc-10yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-inorganic-10yr", panel_id: "slider-inorganic-10yr",
                  label: "Inorganic chemicals", tooltip_text: filter_tooltips["inorganic_chemicals"],
                  field: "inorganic_chemicals_10yr", min_input_id: "min-inorganic-10yr", max_input_id: "max-inorganic-10yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-synthetic-10yr", panel_id: "slider-soc-10yr",
                  label: "Synthetic organic chemicals", tooltip_text: filter_tooltips["synthetic_organic_chemicals"],
                  field: "synthetic_organic_chemicals_10yr", min_input_id: "min-soc-10yr", max_input_id: "max-soc-10yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-vocs-10yr", panel_id: "slider-voc-10yr",
                  label: "Volatile organic chemicals", tooltip_text: filter_tooltips["volatile_organic_chemicals"],
                  field: "volatile_organic_chemicals_10yr", min_input_id: "min-voc-10yr", max_input_id: "max-voc-10yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-coliform-10yr", panel_id: "slider-coliform-10yr",
                  label: "Coliform", tooltip_text: filter_tooltips["total_coliform"],
                  field: "total_coliform_10yr", min_input_id: "min-coliform-10yr", max_input_id: "max-coliform-10yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-stage-1-disinfectants-10yr", panel_id: "slider-stage1-dis-10yr",
                  label: "Stage 1 disinfectants", tooltip_text: filter_tooltips["stage_1_disinfectants"],
                  field: "stage_1_disinfectants_10yr", min_input_id: "min-stage1-dis-10yr", max_input_id: "max-stage1-dis-10yr", nested: true) %>
            <%= render Filters::GroupRangeComponent.new(
                  checkbox_id: "viols-stage-2-disinfectants-10yr", panel_id: "slider-stage2-dis-10yr",
                  label: "Stage 2 disinfectants", tooltip_text: filter_tooltips["stage_2_disinfectants"],
                  field: "stage_2_disinfectants_10yr", min_input_id: "min-stage2-dis-10yr", max_input_id: "max-stage2-dis-10yr", nested: true) %>
          </ul>
          </div>
        </li>
        <% paperwork_5yr_min = filter_range_value("paperwork_violations_5yr", :min) %>
        <% paperwork_5yr_max = filter_range_value("paperwork_violations_5yr", :max) %>
        <% paperwork_5yr = range_active?("paperwork_violations_5yr") %>
        <li class="<%= filter_row_classes %>">
          <input type="checkbox" class="toggle" id="viols-paperwork-5yrs"
                 data-action="change->filter#toggleSubcat"
                 data-panel-id="subcat-paperwork-5yr" <%= checked_if paperwork_5yr %>>
          <label for="viols-paperwork-5yrs">Non-health violations in the last 5 years</label>
          <button type="button" class="<%= filter_info_button_classes %>"
                  data-action="click->filter#toggleSubcatPanel"
                  data-panel-id="subcat-paperwork-5yr"
                  aria-expanded="<%= paperwork_5yr %>"
                  aria-controls="subcat-paperwork-5yr">
            <%= icon("arrow-down", classes: collapse_toggle_icon_classes(expanded: paperwork_5yr)) %>
          </button>
          <div id="subcat-paperwork-5yr" class="<%= paperwork_5yr ? "px-2 py-2" : "hidden px-2 py-2" %>" data-subcat-panel
               data-controller="slider"
               data-slider-field-value="paperwork_violations_5yr"
               data-slider-url-value="<%= histogram_path %>">
            <p class="text-xs text-neutral-400 mb-1">Number of violations</p>
            <svg data-slider-target="chart" class="w-full" height="80" aria-hidden="true"></svg>
            <div class="flex justify-between text-xs mt-1">
              <span data-slider-target="minLabel"></span>
              <span data-slider-target="maxLabel"></span>
            </div>
            <div data-min-max-inputs class="flex items-center gap-1 mt-2 text-sm text-neutral-700">
              <div class="flex flex-col flex-1 min-w-0">
                <input type="text"
                       id="paperwork-5yr-min-text"
                       data-slider-target="minTextInput"
                       data-action="change->slider#textInputChanged keydown.enter->slider#textInputChanged"
                       placeholder="Enter Min"
                       inputmode="numeric"
                       autocomplete="off"
                       aria-label="Minimum filter value"
                       value="<%= paperwork_5yr_min %>"
                       class="w-full text-sm font-bold bg-neutral-50 border border-neutral-300 rounded px-1.5 py-1 text-neutral-700">
              </div>
              <span aria-hidden="true">-</span>
              <div class="flex flex-col flex-1 min-w-0">
                <input type="text"
                       id="paperwork-5yr-max-text"
                       data-slider-target="maxTextInput"
                       data-action="change->slider#textInputChanged keydown.enter->slider#textInputChanged"
                       placeholder="Enter Max"
                       inputmode="numeric"
                       autocomplete="off"
                       aria-label="Maximum filter value"
                       value="<%= paperwork_5yr_max %>"
                       class="w-full text-sm font-bold bg-neutral-50 border border-neutral-300 rounded px-1.5 py-1 text-neutral-700 text-right">
              </div>
            </div>
            <input type="hidden" data-slider-target="minInput" id="min-paperwork-5yr" value="<%= paperwork_5yr_min %>">
            <input type="hidden" data-slider-target="maxInput" id="max-paperwork-5yr" value="<%= paperwork_5yr_max %>">
          </div>
        </li>
        <% paperwork_10yr_min = filter_range_value("paperwork_violations_10yr", :min) %>
        <% paperwork_10yr_max = filter_range_value("paperwork_violations_10yr", :max) %>
        <% paperwork_10yr = range_active?("paperwork_violations_10yr") %>
        <li class="<%= filter_row_classes %>">
          <input type="checkbox" class="toggle" id="viols-paperwork"
                 data-action="change->filter#toggleSubcat"
                 data-panel-id="subcat-paperwork-10yr" <%= checked_if paperwork_10yr %>>
          <label for="viols-paperwork">Non-health violations in the last 10 years</label>
          <button type="button" class="<%= filter_info_button_classes %>"
                  data-action="click->filter#toggleSubcatPanel"
                  data-panel-id="subcat-paperwork-10yr"
                  aria-expanded="<%= paperwork_10yr %>"
                  aria-controls="subcat-paperwork-10yr">
            <%= icon("arrow-down", classes: collapse_toggle_icon_classes(expanded: paperwork_10yr)) %>
          </button>
          <div id="subcat-paperwork-10yr" class="<%= paperwork_10yr ? "px-2 py-2" : "hidden px-2 py-2" %>" data-subcat-panel
               data-controller="slider"
               data-slider-field-value="paperwork_violations_10yr"
               data-slider-url-value="<%= histogram_path %>">
            <p class="text-xs text-neutral-400 mb-1">Number of violations</p>
            <svg data-slider-target="chart" class="w-full" height="80" aria-hidden="true"></svg>
            <div class="flex justify-between text-xs mt-1">
