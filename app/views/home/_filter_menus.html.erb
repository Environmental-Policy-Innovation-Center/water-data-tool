<%# Filter dropdown menus — rendered inside #container-map, positioned absolutely %>
<%# Full filter wiring happens in M6 (depends on M3 PWS API). These are structural shells. %>

<!-- 1. SOURCE -->
<%= render UI::FilterMenuComponent.new(menu_id: 1) do %>
  <div id="container-menu-1-items">
    <h3 class="m-0 px-[15px] py-5 text-base font-medium text-white bg-[#989898]">Primary type</h3>
    <ul class="my-[6px] mb-[10px] mx-0 list-none px-1">
      <li class="px-[15px] py-1.5 hover:bg-neutral-50 [&_label]:align-middle [&_input]:mr-2 [&_input]:inline-block [&_input]:align-middle [&_input.rounded-checkbox]:h-[35px] [&_input.rounded-checkbox]:w-[35px] [&_input:not(.rounded-checkbox)]:size-4"><input type="radio" name="water-source" id="ws-both" checked="checked" data-default /><label for="ws-both">Both ground and surface</label></li>
      <li class="px-[15px] py-1.5 hover:bg-neutral-50 [&_label]:align-middle [&_input]:mr-2 [&_input]:inline-block [&_input]:align-middle [&_input.rounded-checkbox]:h-[35px] [&_input.rounded-checkbox]:w-[35px] [&_input:not(.rounded-checkbox)]:size-4"><input type="radio" name="water-source" id="ws-ground" /><label for="ws-ground">Ground only</label></li>
      <li class="px-[15px] py-1.5 hover:bg-neutral-50 [&_label]:align-middle [&_input]:mr-2 [&_input]:inline-block [&_input]:align-middle [&_input.rounded-checkbox]:h-[35px] [&_input.rounded-checkbox]:w-[35px] [&_input:not(.rounded-checkbox)]:size-4"><input type="radio" name="water-source" id="ws-surface" /><label for="ws-surface">Surface only</label></li>
    </ul>
    <h3 class="m-0 px-[15px] py-5 text-base font-medium text-white bg-[#989898]">Place</h3>
    <div data-controller="place-autocomplete" class="relative mb-2.5">
      <input type="text" class="js-place-search w-full px-2.5 py-1.5 border border-[#ccc] rounded text-[0.95em]"
             placeholder="Search for a city or town..."
             data-place-autocomplete-target="input"
             data-action="input->place-autocomplete#search blur->place-autocomplete#blur"
             autocomplete="off">
      <input type="hidden" id="place-geoid" data-place-autocomplete-target="geoid">
      <ul data-place-autocomplete-target="results" class="place-autocomplete-results" style="display:none;"></ul>
    </div>
    <h3 class="m-0 px-[15px] py-5 text-base font-medium text-white bg-[#989898]">Protection</h3>
    <ul class="my-[6px] mb-[10px] mx-0 list-none px-1">
      <li class="px-[15px] py-1.5 hover:bg-neutral-50 [&_label]:align-middle [&_input]:mr-2 [&_input]:inline-block [&_input]:align-middle [&_input.rounded-checkbox]:h-[35px] [&_input.rounded-checkbox]:w-[35px] [&_input:not(.rounded-checkbox)]:size-4"><input type="checkbox" class="toggle" id="has-source-water-protection"><label for="has-source-water-protection">Has source protection</label></li>
    </ul>
  </div>
<% end %>

<!-- 2. ATTRIBUTES -->
<%= render UI::FilterMenuComponent.new(menu_id: 2) do %>
