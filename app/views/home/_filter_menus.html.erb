<%# Filter menus generated from filter_layout.yml × fields.yml. JS reads the data-filter-* contract emitted here. %>
<% FilterLayout.menus.each_value do |menu| %>
  <%= render UI::FilterMenuPanelComponent.new(
        menu_id: menu[:id],
        more_menu: menu.fetch(:more_menu, false),
        width_class: menu.fetch(:width, "w-[350px]"),
        reset_data_action: menu.fetch(:reset_action, "click->filter#reset"),
        reset_label: menu.fetch(:reset_label, "Reset")) do %>
    <% if menu[:more_menu] %>
      <h2 class="m-0 px-[15px] py-5 text-base font-medium text-white bg-[#989898] hidden sm:block">More filters</h2>
      <%# Placeholders — filter content moves here when its nav button collapses %>
      <div id="more-filter-grp-1"></div>
      <div id="more-filter-grp-2"></div>
      <div id="more-filter-grp-3"></div>
      <div id="more-filter-grp-4"></div>
      <div id="more-filter-grp-5"></div>
    <% end %>
    <div id="container-menu-<%= menu[:id] %>-items">
      <% menu[:categories].each_value do |category| %>
        <%= render "home/filter_category", category: category, menu_id: menu[:id] %>
      <% end %>
    </div>
  <% end %>
<% end %>
