<!-- 3. BOUNDARIES -->
<%= render UI::FilterMenuComponent.new(menu_id: 3) do %>
  <div id="container-menu-3-items">
    <h3 class="m-0 px-[15px] py-5 text-base font-medium text-white bg-[#989898]">Type</h3>
    <ul class="my-[6px] mb-[10px] mx-0 list-none px-1">
      <li class="px-[15px] py-1.5 hover:bg-neutral-50 [&_label]:align-middle [&_input]:mr-2 [&_input]:inline-block [&_input]:align-middle [&_input.rounded-checkbox]:h-[35px] [&_input.rounded-checkbox]:w-[35px] [&_input:not(.rounded-checkbox)]:size-4"><input type="radio" name="boundary-type" id="bt-both" checked="checked" data-default /><label for="bt-both">Both modeled and system sourced</label></li>
      <li class="px-[15px] py-1.5 hover:bg-neutral-50 [&_label]:align-middle [&_input]:mr-2 [&_input]:inline-block [&_input]:align-middle [&_input.rounded-checkbox]:h-[35px] [&_input.rounded-checkbox]:w-[35px] [&_input:not(.rounded-checkbox)]:size-4"><input type="radio" name="boundary-type" id="bt-modeled" /><label for="bt-modeled">Modeled only</label></li>
      <li class="px-[15px] py-1.5 hover:bg-neutral-50 [&_label]:align-middle [&_input]:mr-2 [&_input]:inline-block [&_input]:align-middle [&_input.rounded-checkbox]:h-[35px] [&_input.rounded-checkbox]:w-[35px] [&_input:not(.rounded-checkbox)]:size-4"><input type="radio" name="boundary-type" id="bt-system" /><label for="bt-system">System sourced only</label></li>
    </ul>
    <h3 class="m-0 px-[15px] py-5 text-base font-medium text-white bg-[#989898]">Size</h3>
    <p class="my-2.5 mx-0 px-[15px] py-1.5 text-[0.9em]"><strong class="font-medium">Area in square miles</strong></p>
    <div class="dropdown-selectors">
      <select id="area-min" class="toggle-select min-select left">
        <option value="0" selected>No minimum</option>
        <option value="1">1</option><option value="2">2</option><option value="4">4</option>
        <option value="5">5</option><option value="10">10</option><option value="15">15</option>
        <option value="20">20</option><option value="25">25</option><option value="50">50</option>
        <option value="100">100</option><option value="250">250</option><option value="500">500</option>
      </select>
      <select id="area-max" class="toggle-select max-select right">
        <option value="1">1</option><option value="2">2</option><option value="4">4</option>
        <option value="5">5</option><option value="10">10</option><option value="15">15</option>
        <option value="20">20</option><option value="25">25</option><option value="50">50</option>
        <option value="100">100</option><option value="250">250</option><option value="500">500</option>
        <option value="999999" selected>No maximum</option>
      </select>
    </div>
  </div>
<% end %>

<!-- 4. COMPLIANCE -->
