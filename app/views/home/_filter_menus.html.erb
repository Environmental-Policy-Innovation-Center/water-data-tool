    </ul>
    <h3 class="m-0 px-[15px] py-5 text-base font-medium text-white bg-[#989898]">Facility type</h3>
    <ul class="my-[6px] mb-[10px] mx-0 list-none px-1">
      <li class="px-[15px] py-1.5 hover:bg-neutral-50 [&_label]:align-middle [&_input]:mr-2 [&_input]:inline-block [&_input]:align-middle [&_input.rounded-checkbox]:h-[35px] [&_input.rounded-checkbox]:w-[35px] [&_input:not(.rounded-checkbox)]:size-4"><input type="checkbox" class="toggle" id="is-school-or-daycare"><label for="is-school-or-daycare">School or daycare</label></li>
    </ul>
