<aside id="container-sidebar"
       class="container-nav-panel hide-for-mobile"
       aria-label="Drinking Water Explorer navigation">
  <div>
    <button type="button"
            id="toggle-button"
            class="btn-toggle-panel open"
            aria-label="Toggle sidebar width"></button>
  </div>

  <div class="container-logo flex justify-center px-3">
    <%= image_tag "logo-drinking-water-explorer.png",
          alt: "Drinking Water Explorer",
          class: "mx-auto block h-auto max-w-full" %>
  </div>
  <div class="container-intro hide-when-collapsed-fade">
    <h2 id="sidebar-intro-title">Drinking Water Explorer</h2>
    <p>Use this tool to view and compare public water systems across the country.</p>
  </div>
  <nav class="container-sidebar-nav" aria-label="Main sections">
    <ul class="sidebar-nav">
      <li class="nav-1">
        <a href="javascript:void(0);"
           data-section="map"
           data-action="click->nav#show"
           class="nav-item nav-1 nav-map active"
           aria-current="page">
          <span class="hide-when-collapsed">Explore the Map</span>
        </a>
      </li>
      <li class="nav-2">
        <a href="javascript:void(0);"
           data-section="datasets"
           data-action="click->nav#show"
           class="nav-item nav-2 nav-datasets">
          <span class="hide-when-collapsed">Datasets</span>
        </a>
      </li>
      <li class="nav-3">
        <a href="https://tech-team-data.s3.us-east-1.amazonaws.com/national-dw-tool/public-data-downloads/EPIC's+Drinking+Water+Explorer+Tool+-+Methodology.pdf"
           target="_blank"
           rel="noopener noreferrer"
           class="nav-item nav-3 nav-documentation">
          <span class="hide-when-collapsed">Documentation</span><%= icon "external-link", classes: "inline" %>
        </a>
      </li>
      <li class="nav-4">
        <a href="javascript:void(0);"
           data-section="downloads"
           data-action="click->nav#show"
           class="nav-item nav-4 nav-downloads">
          <span class="hide-when-collapsed">Downloads</span>
        </a>
      </li>
    </ul>
  </nav>

  <div class="container-sidebar-bottom">
    <div class="container-epic-logo flex justify-center px-3 py-3">
      <%= image_tag "EPIC-logo.png",
            alt: "Environmental Policy Innovation Center",
            class: "mx-auto block h-auto max-w-full" %>
    </div>
    <p class="mt-2">
      (<a href="https://creativecommons.org/share-your-work/cclicenses/"
          target="_blank"
          rel="noopener noreferrer">cc</a>)
      <span class="hide-when-collapsed">Environmental Policy<br>Center </span>(EPIC)
    </p>
    <div class="my-6 space-y-2">
      <p>
        <a href="https://github.com/Environmental-Policy-Innovation-Center/national-dw-tool-public"
           target="_blank"
           rel="noopener noreferrer">Github</a><%= icon "external-link", classes: "inline" %>
      </p>
      <p>
        <a href="https://docs.google.com/forms/d/e/1FAIpQLSdj-JcAmFNHnyEGoou74kyL_R1YOUtsFG4dKlYl0TWWwkUcrg/viewform"
           target="_blank"
           rel="noopener noreferrer">Feedback</a><%= icon "external-link", classes: "inline" %>
      </p>
      <p class="hide-when-collapsed">
        <a href="mailto:watertool@policyinnovation.org">Contact EPIC</a><%= icon "email", classes: "inline" %>
      </p>
      <p class="show-when-collapsed hide-when-expanded" style="display:none;">
        <a href="mailto:watertool@policyinnovation.org">Contact</a><%= icon "email", classes: "inline w-3" %>
      </p>
    </div>
    <% if @last_updated %>
      <p class="text-sm">
        <strong>Last updated on:</strong><br>
        <span class="last-updated-date">
          <%= @last_updated.in_time_zone("Eastern Time (US & Canada)").strftime("%m/%d/%Y at %I:%M %p %Z") %>
        </span>
      </p>
    <% end %>
  </div>
</aside>
