<aside id="container-sidebar"
       class="group fixed top-3 left-4 bottom-8 bg-white rounded-xl shadow-md overflow-hidden z-[1000] hidden sm:flex sm:flex-col w-[250px]"
       data-controller="sidebar"
       data-action="resize@window->sidebar#handleResize"
       aria-label="Drinking Water Explorer navigation">
  <%= render UI::CircleButtonComponent.new(
        id: "sidebar-toggle-button",
        aria_label: "Toggle sidebar width",
        data_action: "click->sidebar#toggle",
        classes: "absolute top-2.5 right-2.5"
      ) do %>
    <%= icon "collapse", classes: "h-4 w-4 group-data-[sidebar-collapsed]:hidden" %>
    <%= icon "expand", classes: "h-4 w-4 group-[&:not([data-sidebar-collapsed])]:hidden" %>
  <% end %>

  <div class="flex-1 max-h-10 min-h-4"></div>
  <div class="flex justify-center px-3 group-data-[sidebar-collapsed]:px-0">
    <%= icon "water", classes: "mx-auto block w-[85px] h-auto group-data-[sidebar-collapsed]:w-12" %>
  </div>
  <div class="flex-1 max-h-4 min-h-2 group-data-[sidebar-collapsed]:hidden"></div>
  <div class="pl-5 pr-2.5 min-w-[250px] group-data-[sidebar-collapsed]:hidden">
    <h2 id="sidebar-intro-title" class="text-base font-bold leading-none text-neutral-700 m-0 p-0">Drinking Water Explorer</h2>
    <p class="text-base leading-snug text-[#102033] mt-2.5 mb-0">Use this tool to view and compare public water systems across the country.</p>
  </div>
  <div class="flex-1 max-h-4 min-h-2"></div>

  <div class="flex-1 min-h-0 flex flex-col">
    <nav id="sidebar-nav" class="w-full" aria-label="Main sections">
      <ul class="list-none m-0 p-0">
        <%= render "core_section_nav",
              list_item_class: "px-5 group-data-[sidebar-collapsed]:px-0 group-data-[sidebar-collapsed]:flex group-data-[sidebar-collapsed]:justify-center" %>
      </ul>
    </nav>

    <div class="mt-auto text-center text-neutral-700 [&_a]:text-neutral-700">
      <div class="py-1">
        <div class="flex justify-center px-3">
          <%= icon "epic", classes: "mx-auto block w-9 h-auto" %>
        </div>
        <p class="mt-1 group-data-[sidebar-collapsed]:text-xs group-data-[sidebar-collapsed]:leading-snug">
          (<%= render UI::ExternalLinkComponent.new(url: "https://creativecommons.org/share-your-work/cclicenses/", show_icon: false) do %><span class="sr-only">Creative Commons license</span><span aria-hidden="true">cc</span><% end %>)
          <span>Environmental Policy<br>Center </span>(EPIC)
        </p>
        <div class="my-1 space-y-1 group-data-[sidebar-collapsed]:text-xs">
          <p>
            <%= render UI::ExternalLinkComponent.new(url: "https://github.com/Environmental-Policy-Innovation-Center/national-dw-tool-public", aria_label: "EPIC water tool source code on GitHub") do %>Github<% end %>
          </p>
          <p>
            <%= render UI::ExternalLinkComponent.new(url: "https://docs.google.com/forms/d/e/1FAIpQLSdj-JcAmFNHnyEGoou74kyL_R1YOUtsFG4dKlYl0TWWwkUcrg/viewform", aria_label: "Submit feedback for the Water Explorer tool") do %>Feedback<% end %>
          </p>
          <p>
            <%= render UI::MailtoLinkComponent.new(email: "watertool@policyinnovation.org") do %>Contact EPIC<% end %>
          </p>
        </div>
      </div>
      <% if @last_updated %>
        <div class="py-2">
          <p class="text-sm group-data-[sidebar-collapsed]:text-xs">
            <strong>Latest data update on:</strong><br>
            <span class="last-updated-date">
              <%= @last_updated.in_time_zone("Eastern Time (US & Canada)").strftime("%m/%d/%Y at %I:%M %p %Z") %>
            </span>
          </p>
        </div>
      <% end %>
    </div>
  </div>
</aside>
