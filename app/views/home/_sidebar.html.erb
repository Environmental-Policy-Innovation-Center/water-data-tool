<aside id="container-sidebar"
       class="group fixed top-3 left-4 bottom-8 bg-white rounded-xl shadow-md overflow-y-auto overflow-x-hidden z-[1000] max-[640px]:hidden min-[640px]:flex min-[640px]:flex-col w-[250px]"
       data-controller="sidebar"
       data-action="resize@window->sidebar#handleResize"
       aria-label="Drinking Water Explorer navigation">
  <button type="button"
          id="sidebar-toggle-button"
          class="absolute top-2.5 right-2.5 p-0 m-0 cursor-pointer bg-white border border-neutral-300 rounded-full w-8 h-8 flex items-center justify-center hover:bg-neutral-100"
          data-action="click->sidebar#toggle"
          aria-label="Toggle sidebar width">
    <%= icon "collapse", classes: "h-4 w-4 group-data-[sidebar-collapsed]:hidden" %>
    <%= icon "expand", classes: "h-4 w-4 group-[&:not([data-sidebar-collapsed])]:hidden" %>
  </button>

  <div class="mt-10 flex justify-center px-3 group-data-[sidebar-collapsed]:invisible">
    <%= icon "water", classes: "mx-auto block w-[85px] h-auto" %>
  </div>
  <div class="pl-5 pr-2.5 mt-6 min-w-[250px] group-data-[sidebar-collapsed]:invisible">
    <h2 id="sidebar-intro-title" class="text-base font-bold leading-none text-[#565656] m-0 p-0">Drinking Water Explorer</h2>
    <p class="text-base leading-snug text-[#102033] mt-2.5 mb-0">Use this tool to view and compare public water systems across the country.</p>
  </div>

  <nav id="sidebar-nav" class="mt-4 w-full" aria-label="Main sections">
    <ul class="list-none m-0 p-0">
      <li class="nav-1 group-data-[sidebar-collapsed]:flex group-data-[sidebar-collapsed]:justify-center">
        <button type="button"
           data-section="map"
           data-action="click->nav#show"
           class="nav-item nav-1 nav-map active flex items-center gap-3 px-4 py-2.5 bg-white text-neutral-900 cursor-pointer rounded-full border border-neutral-400 my-2 mx-5 hover:bg-neutral-200 hover:text-black [&.active]:bg-brand-primary [&.active]:border-brand-primary [&.active]:text-white group-data-[sidebar-collapsed]:mx-1 group-data-[sidebar-collapsed]:w-10 group-data-[sidebar-collapsed]:px-0 group-data-[sidebar-collapsed]:justify-center group-data-[sidebar-collapsed]:border-0 group-data-[sidebar-collapsed]:rounded-lg"
           aria-current="page">
          <%= icon "explore", classes: "h-[18px] w-[18px] shrink-0" %>
          <span class="group-data-[sidebar-collapsed]:hidden">Explore the Map</span>
        </button>
      </li>
      <li class="nav-2 group-data-[sidebar-collapsed]:flex group-data-[sidebar-collapsed]:justify-center">
        <button type="button"
           data-section="datasets"
           data-action="click->nav#show"
           class="nav-item nav-2 nav-datasets flex items-center gap-3 px-4 py-2.5 bg-white text-neutral-900 cursor-pointer rounded-full border border-neutral-400 my-2 mx-5 hover:bg-neutral-200 hover:text-black [&.active]:bg-brand-primary [&.active]:border-brand-primary [&.active]:text-white group-data-[sidebar-collapsed]:mx-1 group-data-[sidebar-collapsed]:w-10 group-data-[sidebar-collapsed]:px-0 group-data-[sidebar-collapsed]:justify-center group-data-[sidebar-collapsed]:border-0 group-data-[sidebar-collapsed]:rounded-lg">
          <%= icon "data", classes: "h-[18px] w-[18px] shrink-0" %>
          <span class="group-data-[sidebar-collapsed]:hidden">Datasets</span>
        </button>
      </li>
      <li class="nav-3 group-data-[sidebar-collapsed]:flex group-data-[sidebar-collapsed]:justify-center">
        <a href="https://tech-team-data.s3.us-east-1.amazonaws.com/national-dw-tool/public-data-downloads/EPIC's+Drinking+Water+Explorer+Tool+-+Methodology.pdf"
           target="_blank"
           rel="noopener noreferrer"
           title="Opens in new tab"
           class="nav-item nav-3 nav-documentation flex items-center gap-3 px-4 py-2.5 bg-white text-neutral-900 no-underline rounded-full border border-neutral-400 my-2 mx-5 hover:bg-neutral-200 hover:text-black [&.active]:bg-brand-primary [&.active]:border-brand-primary [&.active]:text-white group-data-[sidebar-collapsed]:mx-1 group-data-[sidebar-collapsed]:w-10 group-data-[sidebar-collapsed]:px-0 group-data-[sidebar-collapsed]:justify-center group-data-[sidebar-collapsed]:border-0 group-data-[sidebar-collapsed]:rounded-lg">
          <%= icon "documentation", classes: "h-[18px] w-[18px] shrink-0" %>
          <span class="group-data-[sidebar-collapsed]:hidden">Documentation</span><%= icon "external-link", classes: "inline ml-1 group-data-[sidebar-collapsed]:hidden" %><span class="sr-only">(opens in new tab)</span>
        </a>
      </li>
      <li class="nav-4 group-data-[sidebar-collapsed]:flex group-data-[sidebar-collapsed]:justify-center">
        <button type="button"
           data-section="downloads"
           data-action="click->nav#show"
           class="nav-item nav-4 nav-downloads flex items-center gap-3 px-4 py-2.5 bg-white text-neutral-900 cursor-pointer rounded-full border border-neutral-400 my-2 mx-5 hover:bg-neutral-200 hover:text-black [&.active]:bg-brand-primary [&.active]:border-brand-primary [&.active]:text-white group-data-[sidebar-collapsed]:mx-1 group-data-[sidebar-collapsed]:w-10 group-data-[sidebar-collapsed]:px-0 group-data-[sidebar-collapsed]:justify-center group-data-[sidebar-collapsed]:border-0 group-data-[sidebar-collapsed]:rounded-lg">
          <%= icon "downloads", classes: "h-[18px] w-[18px] shrink-0" %>
          <span class="group-data-[sidebar-collapsed]:hidden">Downloads</span>
        </button>
      </li>
    </ul>
  </nav>

  <div class="mt-auto pt-4 min-w-[250px] text-center text-[#565656] [&_a]:text-[#565656] group-data-[sidebar-collapsed]:invisible">
    <div class="flex justify-center px-3 py-3">
      <%= icon "epic", classes: "mx-auto block w-9 h-auto" %>
    </div>
    <p class="mt-2">
      (<a href="https://creativecommons.org/share-your-work/cclicenses/"
          target="_blank"
          rel="noopener noreferrer">cc</a>)
      <span>Environmental Policy<br>Center </span>(EPIC)
    </p>
    <div class="my-6 space-y-2">
      <p>
        <a href="https://github.com/Environmental-Policy-Innovation-Center/national-dw-tool-public"
           target="_blank"
           rel="noopener noreferrer"
           title="Opens in new tab">Github<%= icon "external-link", classes: "inline ml-0.5" %><span class="sr-only">(opens in new tab)</span></a>
      </p>
      <p>
        <a href="https://docs.google.com/forms/d/e/1FAIpQLSdj-JcAmFNHnyEGoou74kyL_R1YOUtsFG4dKlYl0TWWwkUcrg/viewform"
           target="_blank"
           rel="noopener noreferrer"
           title="Opens in new tab">Feedback<%= icon "external-link", classes: "inline ml-0.5" %><span class="sr-only">(opens in new tab)</span></a>
      </p>
      <p>
        <a href="mailto:watertool@policyinnovation.org">Contact EPIC</a><%= icon "email", classes: "inline" %>
      </p>
    </div>
    <% if @last_updated %>
      <p class="text-sm">
        <strong>Last updated on:</strong><br>
        <span class="last-updated-date">
          <%= @last_updated.in_time_zone("Eastern Time (US & Canada)").strftime("%m/%d/%Y at %I:%M %p %Z") %>
        </span>
      </p>
    <% end %>
  </div>
</aside>
