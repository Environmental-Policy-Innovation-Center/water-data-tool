<%# Reusable class strings for data cells. Header cells use UI::TableHeaderComponent. %>
<% td = "px-3 py-2 border-b border-gray-100 overflow-hidden max-w-48" %>
<% td_check_base = "px-2 py-2 border-b border-gray-100 w-10 text-center md:group-hover:bg-blue-50 transition-colors" %>
<% td_sticky_base = "sticky left-0 z-10 font-normal text-left md:group-hover:bg-blue-50 transition-colors px-3 py-2 border-b border-gray-100 overflow-hidden max-w-xs" %>
<% td_num = "px-3 py-2 border-b border-gray-100 tabular-nums text-right overflow-hidden" %>

<turbo-frame id="data-table">
  <%# Single scroll region handles both axes; sticky <th top-0> sticks within this container %>
  <div class="table-scroll overflow-auto flex-1 min-h-0" role="region" aria-label="Public water systems data" tabindex="0">
    <table class="border-collapse text-sm">
      <caption class="sr-only">
        Public water systems — <%= @pagy.count %> total<%= params[:search].present? ? ", filtered by search: #{h params[:search]}" : "" %>
      </caption>
      <thead>
        <tr>
          <%# ── Row selection ──────────────────────────────────────── %>
          <%= render UI::TableHeaderComponent.new(size: :check) %>
          <%# ── Core identity ─────────────────────────────────────── %>
          <%= render UI::TableHeaderComponent.new(label: "Utility Name", column: "pws_name", size: :sticky) %>
          <%= render UI::TableHeaderComponent.new(label: "Utility ID", column: "pwsid") %>
          <%= render UI::TableHeaderComponent.new(label: "EPA Facility Report", size: :sm) %>
          <%= render UI::TableHeaderComponent.new(label: "State", column: "stusps", size: :sm) %>
          <%# ── Geography & system type ─────────────────────────── %>
          <%= render UI::TableHeaderComponent.new(label: "County", column: "counties", size: :wide) %>
          <%= render UI::TableHeaderComponent.new(label: "Source type", column: "gw_sw_code") %>
          <%= render UI::TableHeaderComponent.new(label: "Source protection", column: "source_water_protection_code") %>
          <%= render UI::TableHeaderComponent.new(label: "Ownership", column: "owner_type") %>
          <%= render UI::TableHeaderComponent.new(label: "Authority", column: "primacy_type") %>
          <%= render UI::TableHeaderComponent.new(label: "Wholesaler", column: "is_wholesaler") %>
          <%= render UI::TableHeaderComponent.new(label: "Facility type (School or daycare)", column: "is_school_or_daycare") %>
          <%= render UI::TableHeaderComponent.new(label: "Boundary type", column: "symbology_field") %>
          <%= render UI::TableHeaderComponent.new(label: "Size (sq mi)", column: "area_sq_miles") %>
          <%= render UI::TableHeaderComponent.new(label: "Open violations", column: "open_health_viol") %>
          <%# ── Violations — 5 year ─────────────────────────────── %>
          <%= render UI::TableHeaderComponent.new(label: "Health violations (5yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Groundwater rule violations (5yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Surface water treatment violations (5yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Lead & copper violations (5yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Radionuclides violations (5yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Inorganic chemicals violations (5yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Synthetic organic chemicals violations (5yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Volatile organic chemicals violations (5yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Coliform violations (5yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Stage 1 disinfectants violations (5yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Stage 2 disinfectants violations (5yr)") %>
          <%# ── Violations — 10 year ────────────────────────────── %>
          <%= render UI::TableHeaderComponent.new(label: "Health violations (10yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Groundwater rule violations (10yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Surface water treatment violations (10yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Lead & copper violations (10yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Radionuclides violations (10yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Inorganic chemicals violations (10yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Synthetic organic chemicals violations (10yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Volatile organic chemicals violations (10yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Coliform violations (10yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Stage 1 disinfectants violations (10yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Stage 2 disinfectants violations (10yr)") %>
          <%# ── Non-health violations ───────────────────────────── %>
          <%= render UI::TableHeaderComponent.new(label: "Non-health violations (5yr)") %>
          <%= render UI::TableHeaderComponent.new(label: "Non-health violations (10yr)") %>
          <%# ── Boil water ──────────────────────────────────────── %>
          <%= render UI::TableHeaderComponent.new(label: "Boil water notices") %>
          <%# ── Demographics ────────────────────────────────────── %>
          <%= render UI::TableHeaderComponent.new(label: "Population size") %>
          <%= render UI::TableHeaderComponent.new(label: "Population density (per sq mi)") %>
          <%= render UI::TableHeaderComponent.new(label: "Households below poverty line") %>
          <%= render UI::TableHeaderComponent.new(label: "Unemployment") %>
          <%= render UI::TableHeaderComponent.new(label: "Median household income") %>
          <%= render UI::TableHeaderComponent.new(label: "Higher education attainment") %>
          <%= render UI::TableHeaderComponent.new(label: "Children under 5") %>
          <%= render UI::TableHeaderComponent.new(label: "Elderly over 61") %>
          <%= render UI::TableHeaderComponent.new(label: "People of color") %>
          <%= render UI::TableHeaderComponent.new(label: "White") %>
          <%= render UI::TableHeaderComponent.new(label: "Black") %>
          <%= render UI::TableHeaderComponent.new(label: "American Indian & Alaskan Native") %>
          <%= render UI::TableHeaderComponent.new(label: "Native Hawaiian & Pacific Islander") %>
          <%= render UI::TableHeaderComponent.new(label: "Asian") %>
          <%= render UI::TableHeaderComponent.new(label: "Latino/a") %>
          <%= render UI::TableHeaderComponent.new(label: "Other race") %>
          <%= render UI::TableHeaderComponent.new(label: "Mixed race") %>
          <%= render UI::TableHeaderComponent.new(label: "Annual water & sewer bill") %>
          <%# ── Environmental justice ───────────────────────────── %>
          <%= render UI::TableHeaderComponent.new(label: "Disadvantaged area") %>
          <%= render UI::TableHeaderComponent.new(label: "Social Vulnerability Index") %>
          <%= render UI::TableHeaderComponent.new(label: "Climate Vulnerability Index") %>
          <%# ── Funding ─────────────────────────────────────────── %>
          <%= render UI::TableHeaderComponent.new(label: "SRF financing (2021–2025) — times received") %>
          <%= render UI::TableHeaderComponent.new(label: "SRF assistance (2021–2025)") %>
          <%= render UI::TableHeaderComponent.new(label: "SRF principal forgiveness (2021–2025)") %>
          <%# ── Watershed hazards ───────────────────────────────── %>
          <%= render UI::TableHeaderComponent.new(label: "Source water connections") %>
          <%= render UI::TableHeaderComponent.new(label: "Pollution permits with breaches") %>
          <%= render UI::TableHeaderComponent.new(label: "Underground storage tanks") %>
          <%= render UI::TableHeaderComponent.new(label: "Risk management plan facilities") %>
          <%= render UI::TableHeaderComponent.new(label: "Impaired or threatened streams") %>
        </tr>
      </thead>
      <tbody>
        <% sort_is_pws_name = params[:sort] == "pws_name" %>
        <% @systems.each_with_index do |pws, idx| %>
          <% row_stripe = idx.even? ? "bg-white" : "bg-gray-50" %>
          <% td_check  = "#{td_check_base} #{sort_is_pws_name ? 'bg-blue-50' : row_stripe}" %>
          <% td_sticky = "#{td_sticky_base} #{sort_is_pws_name ? 'bg-blue-50' : row_stripe}" %>
          <% vs  = pws.violations_summary %>
          <% dm  = pws.demographic %>
          <% ej  = pws.environmental_justice %>
          <% fs  = pws.funding_summary %>
          <% wh  = pws.watershed_hazard %>
          <% bws = pws.boil_water_summary %>
          <tr class="group <%= row_stripe %> md:hover:bg-blue-50 transition-colors">
            <%# ── Row selection ───────────────────────────────── %>
            <td class="<%= td_check %>">
              <input type="checkbox"
                     class="cursor-pointer"
                     value="<%= pws.pwsid %>"
                     aria-label="Select <%= pws.pws_name %>"
                     data-row-selection-target="row"
                     data-action="change->row-selection#toggle">
            </td>
            <%# ── Core identity ─────────────────────────────────── %>
            <th class="<%= td_sticky %>" scope="row"><%= pws.pws_name %></th>
            <td class="<%= td %><%= col_highlight("pwsid") %>"><%= pws.pwsid %></td>
            <td class="<%= td %>">
              <% if pws.detailed_facility_report.present? %>
                <%= link_to "report",
                    pws.detailed_facility_report,
                    target: "_blank",
                    rel: "noopener noreferrer",
                    class: "text-blue-600 md:hover:underline focus:underline focus:outline-none",
                    aria: {label: "EPA facility report for #{pws.pws_name} (opens in new tab)"} %>
              <% end %>
            </td>
            <td class="<%= td %><%= col_highlight("stusps") %>"><%= fmt_str(pws.stusps) %></td>
            <%# ── Geography & system type ─────────────────────── %>
            <td class="<%= td %><%= col_highlight("counties") %>"><%= fmt_str(pws.counties) %></td>
            <td class="<%= td %><%= col_highlight("gw_sw_code") %>"><%= fmt_str(pws.gw_sw_code) %></td>
            <td class="<%= td %><%= col_highlight("source_water_protection_code") %>"><%= fmt_str(pws.source_water_protection_code) %></td>
            <td class="<%= td %><%= col_highlight("owner_type") %>"><%= fmt_str(pws.owner_type) %></td>
            <td class="<%= td %><%= col_highlight("primacy_type") %>"><%= fmt_str(pws.primacy_type) %></td>
            <td class="<%= td %><%= col_highlight("is_wholesaler") %>"><%= fmt_bool(pws.is_wholesaler) %></td>
            <td class="<%= td %><%= col_highlight("is_school_or_daycare") %>"><%= fmt_bool(pws.is_school_or_daycare) %></td>
            <td class="<%= td %><%= col_highlight("symbology_field") %>"><%= fmt_str(pws.symbology_field) %></td>
            <td class="<%= td_num %><%= col_highlight("area_sq_miles") %>"><%= fmt_dec(pws.area_sq_miles) %></td>
            <td class="<%= td_num %><%= col_highlight("open_health_viol") %>"><%= fmt_num(pws.open_health_viol) %></td>
            <%# ── Violations — 5 year ─────────────────────────── %>
            <td class="<%= td_num %>"><%= fmt_num(vs&.health_violations_5yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.groundwater_rule_5yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.surface_water_treatment_5yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.lead_and_copper_5yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.radionuclides_5yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.inorganic_chemicals_5yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.synthetic_organic_chemicals_5yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.volatile_organic_chemicals_5yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.total_coliform_5yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.stage_1_disinfectants_5yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.stage_2_disinfectants_5yr) %></td>
            <%# ── Violations — 10 year ────────────────────────── %>
            <td class="<%= td_num %>"><%= fmt_num(vs&.health_violations_10yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.groundwater_rule_10yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.surface_water_treatment_10yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.lead_and_copper_10yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.radionuclides_10yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.inorganic_chemicals_10yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.synthetic_organic_chemicals_10yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.volatile_organic_chemicals_10yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.total_coliform_10yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.stage_1_disinfectants_10yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.stage_2_disinfectants_10yr) %></td>
            <%# ── Non-health violations ───────────────────────── %>
            <td class="<%= td_num %>"><%= fmt_num(vs&.paperwork_violations_5yr) %></td>
            <td class="<%= td_num %>"><%= fmt_num(vs&.paperwork_violations_10yr) %></td>
            <%# ── Boil water ──────────────────────────────────── %>
            <td class="<%= td_num %>"><%= fmt_num(bws&.total_notices) %></td>
            <%# ── Demographics ────────────────────────────────── %>
            <td class="<%= td_num %>"><%= fmt_num(dm&.total_population) %></td>
            <td class="<%= td_num %>"><%= fmt_dec(dm&.population_density, precision: 0) %></td>
            <td class="<%= td_num %>"><%= fmt_pct(dm&.poverty_rate) %></td>
            <td class="<%= td_num %>"><%= fmt_pct(dm&.unemployment_rate) %></td>
            <td class="<%= td_num %>"><%= fmt_cur(dm&.median_household_income) %></td>
            <td class="<%= td_num %>"><%= fmt_pct(dm&.bachelors_degree_rate) %></td>
            <td class="<%= td_num %>"><%= fmt_pct(dm&.age_under_5_rate) %></td>
            <td class="<%= td_num %>"><%= fmt_pct(dm&.age_over_61_rate) %></td>
            <td class="<%= td_num %>"><%= fmt_pct(dm&.poc_rate) %></td>
            <td class="<%= td_num %>"><%= fmt_pct(dm&.white_rate) %></td>
            <td class="<%= td_num %>"><%= fmt_pct(dm&.black_rate) %></td>
            <td class="<%= td_num %>"><%= fmt_pct(dm&.aian_rate) %></td>
            <td class="<%= td_num %>"><%= fmt_pct(dm&.napi_rate) %></td>
            <td class="<%= td_num %>"><%= fmt_pct(dm&.asian_rate) %></td>
            <td class="<%= td_num %>"><%= fmt_pct(dm&.hispanic_rate) %></td>
            <td class="<%= td_num %>"><%= fmt_pct(dm&.other_race_rate) %></td>
            <td class="<%= td_num %>"><%= fmt_pct(dm&.mixed_race_rate) %></td>
            <td class="<%= td %>"><%= fmt_str(dm&.most_common_rate_tier) %></td>
            <%# ── Environmental justice ───────────────────────── %>
            <td class="<%= td_num %>"><%= fmt_pct(ej&.cejst_disadvantaged_pct) %></td>
            <td class="<%= td_num %>"><%= fmt_pct(ej&.svi_overall_pctl) %></td>
            <td class="<%= td_num %>"><%= fmt_pct(ej&.cvi_overall_score) %></td>
            <%# ── Funding ─────────────────────────────────────── %>
            <td class="<%= td_num %>"><%= fmt_num(fs&.times_funded) %></td>
            <td class="<%= td_num %>"><%= fmt_cur(fs&.total_srf_assistance, precision: 2) %></td>
            <td class="<%= td_num %>"><%= fmt_cur(fs&.total_principal_forgiveness, precision: 2) %></td>
            <%# ── Watershed hazards ───────────────────────────── %>
            <td class="<%= td_num %>"><%= fmt_num(wh&.num_facilities) %></td>
            <td class="<%= td_num %>"><%= fmt_num(wh&.permit_effluent_violations) %></td>
            <td class="<%= td_num %>"><%= fmt_num(wh&.open_underground_storage_tanks) %></td>
            <td class="<%= td_num %>"><%= fmt_num(wh&.risk_management_plan_facilities) %></td>
            <td class="<%= td_num %>"><%= fmt_num(wh&.impaired_streams_303d) %></td>
          </tr>
        <% end %>
        <% if @systems.empty? %>
          <tr>
            <td colspan="69" class="px-3 py-8 text-center text-gray-500">No results match the current filters.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# Bottom nav bar — 3 columns: entry count | pagination nav | map/table toggle %>
  <nav class="flex-shrink-0 flex items-center gap-4 text-sm border-t border-gray-200 px-4 py-3" aria-label="Table navigation">
    <%# Col 1 — entry count, left-aligned, never wraps %>
    <div class="shrink-0 whitespace-nowrap text-gray-500">
      <% if @pagy.pages > 1 %>
        Showing <%= number_with_delimiter(@pagy.from) %> to <%= number_with_delimiter(@pagy.to) %> of <%= number_with_delimiter(@pagy.count) %> entries
      <% else %>
        Showing <%= number_with_delimiter(@pagy.count) %> entries
      <% end %>
    </div>

    <%# Col 2 — pagination controls, centered %>
    <div class="flex-1 min-w-0 flex items-center justify-center gap-1">
      <% if @pagy.pages > 1 %>
        <%# First %>
        <% if @pagy.page > 1 %>
          <%= link_to "«",
              url_for(request.query_parameters.merge("page" => 1)),
              class: "border border-gray-300 rounded px-2 py-1 md:hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-400",
              aria: {label: "Go to first page"} %>
        <% else %>
          <span class="border border-gray-200 rounded px-2 py-1 text-gray-300" aria-disabled="true">«</span>
        <% end %>

        <%# Previous %>
        <% if @pagy.previous %>
          <%= link_to "‹",
              url_for(request.query_parameters.merge("page" => @pagy.previous)),
              class: "border border-gray-300 rounded px-2 py-1 md:hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-400",
              aria: {label: "Go to previous page"} %>
        <% else %>
          <span class="border border-gray-200 rounded px-2 py-1 text-gray-300" aria-disabled="true">‹</span>
        <% end %>

        <%# Page input form — submits as a Turbo Frame navigation %>
        <form method="get" action="/table" data-turbo-frame="data-table" class="flex items-center gap-1.5">
          <% request.query_parameters.except("page").each do |k, v| %>
            <% if v.is_a?(Array) %>
              <% v.each do |item| %><input type="hidden" name="<%= "#{k}[]" %>" value="<%= item %>"><% end %>
            <% else %>
              <input type="hidden" name="<%= k %>" value="<%= v %>">
            <% end %>
          <% end %>
          <input type="number" name="page" value="<%= @pagy.page %>"
                 min="1" max="<%= @pagy.last %>"
                 autocomplete="off"
                 class="border border-gray-300 rounded px-1.5 py-1 w-14 text-center focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-400"
                 aria-label="Page number">
          <span class="text-gray-500 whitespace-nowrap">of <%= number_with_delimiter(@pagy.last) %></span>
          <button type="submit" class="sr-only">Go to page</button>
        </form>

        <%# Next %>
        <% if @pagy.next %>
          <%= link_to "›",
              url_for(request.query_parameters.merge("page" => @pagy.next)),
              class: "border border-gray-300 rounded px-2 py-1 md:hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-400",
              aria: {label: "Go to next page"} %>
        <% else %>
          <span class="border border-gray-200 rounded px-2 py-1 text-gray-300" aria-disabled="true">›</span>
        <% end %>

        <%# Last %>
        <% if @pagy.page < @pagy.last %>
          <%= link_to "»",
              url_for(request.query_parameters.merge("page" => @pagy.last)),
              class: "border border-gray-300 rounded px-2 py-1 md:hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-400",
              aria: {label: "Go to last page"} %>
        <% else %>
          <span class="border border-gray-200 rounded px-2 py-1 text-gray-300" aria-disabled="true">»</span>
        <% end %>
      <% end %>
    </div>

  </nav>
</turbo-frame>
