<div data-controller="datasets">
  <%# Sticky header -%>
  <div class="datasets-header sticky top-0 z-[9999999] bg-white px-9 pt-4 pb-3 border-b border-gray-200">
    <div class="flex flex-col md:flex-row md:items-start">

      <%# Left: title, count, description -%>
      <div class="flex-1 min-w-0">
        <h3 class="m-0 mb-3 font-bold">Datasets</h3>
        <p class="m-0 mb-3" data-datasets-target="noFilters"><%= datasets.count %> datasets available</p>
        <div class="inline-flex items-center gap-4 mb-3" style="display:none;" data-datasets-target="showAllBar">
          <p class="m-0">Showing <span data-datasets-target="filteredCount"></span> of <%= datasets.count %> datasets available</p>
          <button class="px-5 py-2.5 bg-white text-neutral-700 border border-neutral-400 rounded-full text-sm cursor-pointer hover:bg-neutral-200"
                  data-action="click->datasets#showAll">show all</button>
        </div>
        <p class="m-0 text-sm text-neutral-700">This inventory of drinking water datasets includes information from various public data providers. Here, you can learn details about specific sources and considerations for use. Please visit the documentation for additional information.</p>
      </div>

      <%# Right: recommend button + filter/sort toggles -%>
      <div class="flex-1 mt-4 md:mt-0 md:ml-8">
        <div class="flex flex-col items-center md:items-end gap-3">
          <a href="https://docs.google.com/forms/d/e/1FAIpQLSc6H73GVlF-dlmJrjpRa1J-kgkbzGIHoys5Tcnn3DNzCZlt4Q/viewform?usp=dialog"
             target="_blank" rel="noopener noreferrer"
             class="inline-block px-5 py-2.5 bg-brand-primary text-white no-underline rounded-full border border-brand-primary text-sm">
            Recommend Datasets
          </a>
          <p class="text-sm text-neutral-700 m-0">EPIC wants to know what other datasets should be included in the tool.</p>
          <div class="flex gap-3">
            <button type="button"
                    data-action="click->datasets#togglePanel"
                    data-panel="filter"
                    aria-expanded="false"
                    aria-controls="datasets-filter-panel"
                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-neutral-700 border border-neutral-400 rounded-full text-sm hover:bg-neutral-200 cursor-pointer">
              <%= image_tag "icons/filter.svg", class: "w-4 h-4", alt: "" %>
              Filter
            </button>
            <button type="button"
                    data-action="click->datasets#togglePanel"
                    data-panel="sort"
                    aria-expanded="false"
                    aria-controls="datasets-sort-panel"
                    class="inline-flex items-center px-5 py-2.5 bg-white text-neutral-700 border border-neutral-400 rounded-full text-sm hover:bg-neutral-200 cursor-pointer">
              Sort
            </button>
          </div>
        </div>
      </div>
    </div>

    <%# Filter panel -%>
    <div id="datasets-filter-panel" class="pt-4" style="display:none;" data-datasets-target="filterPanel">
      <p class="font-semibold text-sm mb-3">Filter</p>
      <div class="flex flex-wrap gap-8">
        <div>
          <p class="text-sm text-neutral-600 italic mb-2">Data source:</p>
          <div class="relative inline-block">
            <select class="appearance-none bg-white border border-neutral-400 text-neutral-700 pl-5 pr-10 py-2.5 rounded-full text-sm cursor-pointer"
                    name="ds-dataSource" id="ds-dataSource"
                    data-action="change->datasets#filterBySource"
                    data-datasets-target="sourceSelect">
              <option value="" selected>Show all</option>
              <option value="AK-Department-of-Environmental-Conservation">AK Department of Environmental Conservation</option>
              <option value="AR-Department-of-Health">AR Department of Health</option>
              <option value="Center-for-Disease-Control">Center for Disease Control</option>
              <option value="Environmental-Defense-Fund">Environmental Defense Fund</option>
              <option value="Florida-Health">Florida Health</option>
              <option value="Louisiana-Department-of-Health">Louisiana Department of Health</option>
              <option value="Maine-Department-of-Health-and-Human-Services">Maine Department of Health and Human Services</option>
              <option value="Massachusetts-Department-of-Environmental-Protection">Massachusetts Department of Environmental Protection</option>
              <option value="New-Mexico-Environment-Department">New Mexico Environment Department</option>
              <option value="Ohio-Environmental-Protection-Agency">Ohio Environmental Protection Agency</option>
              <option value="opha">Oregon Public Health Authority</option>
              <option value="Public-Environmental-Data-Partners">Public Environmental Data Partners</option>
              <option value="Rhode-Island-Department-of-Health">Rhode Island Department of Health</option>
              <option value="State-of-Missouri-Data-Portal">State of Missouri Data Portal</option>
              <option value="TCEQ">Texas Commission on Environmental Quality (TCEQ)</option>
              <option value="census">U.S. Census Bureau</option>
              <option value="epa">U.S. Environmental Protection Agency (EPA)</option>
              <option value="Washington-Department-of-Health">Washington Department of Health</option>
              <option value="WV-Department-of-Health-and-Human-Services">WV Department of Health and Human Services</option>
            </select>
            <span class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-neutral-500 text-xs">▾</span>
          </div>
        </div>
        <div>
          <p class="text-sm text-neutral-600 italic mb-2">Update frequency:</p>
          <div class="flex gap-2" data-filter-group="update-frequency">
            <button type="button" class="btn-filter px-5 py-2.5 bg-white text-neutral-700 border border-neutral-400 rounded-full text-sm cursor-pointer hover:bg-neutral-200"
                    data-action="click->datasets#filterByFrequency" data-frequency="annually" aria-pressed="false">Annually</button>
            <button type="button" class="btn-filter px-5 py-2.5 bg-white text-neutral-700 border border-neutral-400 rounded-full text-sm cursor-pointer hover:bg-neutral-200"
                    data-action="click->datasets#filterByFrequency" data-frequency="quarterly" aria-pressed="false">Quarterly</button>
            <button type="button" class="btn-filter px-5 py-2.5 bg-white text-neutral-700 border border-neutral-400 rounded-full text-sm cursor-pointer hover:bg-neutral-200"
                    data-action="click->datasets#filterByFrequency" data-frequency="static" aria-pressed="false">Static</button>
          </div>
        </div>
      </div>
    </div>

    <%# Sort panel -%>
    <div id="datasets-sort-panel" class="pt-4" style="display:none;" data-datasets-target="sortPanel">
      <p class="font-semibold text-sm mb-3">Sort by:</p>
      <div class="flex flex-wrap gap-8">
        <div>
          <p class="text-sm text-neutral-600 italic mb-2">Last updated</p>
          <div class="flex gap-2 items-center">
            <button type="button" class="btn-sort px-5 py-2.5 bg-white text-neutral-700 border border-neutral-400 rounded-full text-sm cursor-pointer hover:bg-neutral-200"
                    data-action="click->datasets#sortByDate" data-direction="desc" aria-pressed="false">Newest</button>
            <button type="button" class="btn-sort px-5 py-2.5 bg-white text-neutral-700 border border-neutral-400 rounded-full text-sm cursor-pointer hover:bg-neutral-200"
                    data-action="click->datasets#sortByDate" data-direction="asc" aria-pressed="false">Oldest</button>
            <button type="button"
                    class="ml-2 px-5 py-2.5 bg-white text-neutral-700 border border-neutral-400 rounded-full text-sm cursor-pointer hover:bg-neutral-200"
                    data-action="click->datasets#resetSort"
                    data-datasets-target="resetSort"
                    style="display:none;">reset order</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Card grid -%>
  <div class="grid grid-cols-1 md:grid-cols-2 mx-4" data-datasets-target="grid">
    <% datasets.each do |ds| %>
      <%= render UI::DatasetCardComponent.new(**ds) %>
    <% end %>
  </div>

  <%# Empty state -%>
  <div id="no-results" class="px-9 py-8 text-neutral-600" style="display:none;" data-datasets-target="noResults">
    <p>No results for the selected filters</p>
  </div>
</div>
