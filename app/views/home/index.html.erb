<%# Mobile header (hidden on desktop via CSS) %>
<div class="mobile-header hide-for-desktop">
  <div class="m-header-left"><%= image_tag "logo-drinking-water-explorer.png", class: "logo" %></div>
  <h1>Drinking Water Explorer</h1>
  <div class="m-header-right">
    <a href="javascript:void(0)" id="mobile-menu-toggle" class="mobile-btn closed" data-action="click->nav#toggleMobile">
      <%= image_tag "icon-mobile-menu.png", class: "mm-icon-bars" %>
      <%= image_tag "icon-mobile-menu-x.png", class: "mm-icon-x hidden" %>
    </a>
  </div>
</div>

<%# Loading mask — hidden by map_controller once map is ready %>
<div id="loading-mask">
  <p>LOADING DATA...</p>
</div>

<%# Active filter tag list (shown above map when filters are applied) %>
<div id="filter-list-container" style="display:none;">
  <small>Active Filters</small>
  <ul id="filter-list">
    <%# Filled dynamically by filter_controller %>
  </ul>
</div>

<%# Left sidebar navigation %>
<%= render "sidebar" %>

<%# =====================================================
    Map view (default section)
    ===================================================== %>
<div id="container-map" class="container-main-content"
     data-controller="map filter"
     data-map-tile-url-value="/tiles/{z}/{x}/{y}">

  <%# Filter tab bar %>
  <div id="container-map-ui-top" class="container-map-ui">
    <ul>
      <%# Geocoder search — populated by map_controller once map loads %>
      <li id="geocoder-li" class="geocoder-li"></li>
      <li class="filter-1">
        <div class="container-filter-count container-filter-count-menu-1">
          <span class="filter-count-group-1">0</span>
        </div>
        <a href="javascript:void(0);" data-menu="1" class="filter-menu-btn" id="container-menu-btn-1" data-action="click->filter#toggleMenu">Source</a>
      </li>
      <li class="filter-2">
        <div class="container-filter-count container-filter-count-menu-2">
          <span class="filter-count-group-2">0</span>
        </div>
        <a href="javascript:void(0);" data-menu="2" class="filter-menu-btn" id="container-menu-btn-2" data-action="click->filter#toggleMenu">Attributes</a>
      </li>
      <li class="filter-3">
        <div class="container-filter-count container-filter-count-menu-3">
          <span class="filter-count-group-3">0</span>
        </div>
        <a href="javascript:void(0);" data-menu="3" class="filter-menu-btn" id="container-menu-btn-3" data-action="click->filter#toggleMenu">Boundaries</a>
      </li>
      <li class="filter-4">
        <div class="container-filter-count container-filter-count-menu-4">
          <span class="filter-count-group-4">0</span>
        </div>
        <a href="javascript:void(0);" data-menu="4" class="filter-menu-btn" id="container-menu-btn-4" data-action="click->filter#toggleMenu">Compliance</a>
      </li>
      <li class="filter-5">
        <div class="container-filter-count container-filter-count-menu-5">
          <span class="filter-count-group-5">0</span>
        </div>
        <a href="javascript:void(0);" data-menu="5" class="filter-menu-btn" id="container-menu-btn-5" data-action="click->filter#toggleMenu">Population</a>
      </li>
      <li class="filter-10">
        <div class="container-filter-count container-filter-count-menu-10">
          <span class="filter-count-group-10">0</span>
        </div>
        <a href="javascript:void(0);" data-menu="10" class="filter-menu-btn" id="container-menu-btn-10" data-action="click->filter#toggleMenu">More</a>
      </li>
    </ul>
  </div>

  <%# Filter dropdown menus %>
  <%= render "filter_menus" %>

  <%# Mapbox GL JS canvas %>
  <div id="map"></div>

  <%# Region shortcut buttons (below +/− zoom controls) %>
  <div id="container-ak-hi" class="container-ak-hi-desktop hide-for-table">
    <a href="javascript:void(0);" title="Zoom to 48 states"
       data-action="click->map#zoom48">48</a>
    <a href="javascript:void(0);" title="Zoom to Alaska"
       data-action="click->map#zoomAk">AK</a>
    <a href="javascript:void(0);" title="Zoom to Hawaii"
       data-action="click->map#zoomHi">HI</a>
    <hr class="region-divider">
    <a href="javascript:void(0);" title="Zoom to Puerto Rico (territory)"
       data-action="click->map#zoomPr" class="territory-btn">PR</a>
    <a href="javascript:void(0);" title="Zoom to Guam (territory)"
       data-action="click->map#zoomGu" class="territory-btn">GU</a>
    <a href="javascript:void(0);" title="Zoom to Northern Mariana Islands (territory)"
       data-action="click->map#zoomMp" class="territory-btn">MP</a>
  </div>

  <%# Intro tooltip — bottom right of map canvas %>
  <div id="container-map-content-bottom" class="hide-for-table">
    <div class="map-content-wrapper map-content-wrapper-desktop map-content-intro hide-for-table">
      <div class="intro-content">
        <p><strong>How to use this tool:</strong></p>
        <p>Search or zoom into the map to see information about public drinking water systems in areas of interest. Use the filters to customize the display.</p>
      </div>
    </div>
  </div>

  <turbo-frame id="stats-bar"></turbo-frame>

  <%# Detail data loaded via Mapbox popup on map click;
      full report loaded into report-body Turbo Frame below %>

  <%# Map/Table view toggle — bottom right of map canvas %>
  <div id="container-map-ui-bottom" class="container-map-ui hide-for-mobile">
    <ul>
      <li>
        <a href="javascript:void(0);" data-section="map" class="nav-item nav-map-toggle active"
           data-action="click->nav#show">
          <%= image_tag "icon-map-toggle-white.png", class: "map-white" %>
          <%= image_tag "icon-map-toggle-dark.png", class: "map-dark" %>
          Map
        </a>
      </li>
      <li>
        <a href="javascript:void(0);" data-section="table" class="nav-item nav-table"
           data-action="click->nav#show">
          <%= image_tag "icon-table-dark.png", class: "table-dark" %>
          <%= image_tag "icon-table-white.png", class: "table-white" %>
          Table
        </a>
      </li>
    </ul>
  </div>

  <%# =====================================================
      Table view — lives inside container-map so the filter
      bar stays visible when the user switches to it.
      Shown/hidden via the .table-mode class on container-map.
      ===================================================== %>
  <div id="container-table">
    <div class="container-section-inner">
      <div class="table-header">
        <div class="table-head-col-1">
          <p><strong>Public Water Utilities <span class="geo-filter"></span></strong></p>
        </div>
        <div class="table-head-col-2" data-controller="export">
          <a href="#" class="btn-export" data-action="click->export#download">
            <%= image_tag "icon-downloads-white.png" %>Export
          </a>
          <input type="radio" name="file-type" id="file-csv" value="csv" checked data-export-target="format" /><label for="file-csv">.csv</label>
          <input type="radio" name="file-type" id="file-geojson" value="geojson" class="file-geojson" data-export-target="format" /><label for="file-geojson" class="file-geojson">.geojson</label>
        </div>
      </div>

      <%# Table loaded via Turbo Frame — filter_controller sets src on table:show %>
      <turbo-frame id="data-table" aria-live="polite" aria-label="Public water systems table">
        <p class="px-3 py-8 text-center text-gray-400 text-sm">Loading data table…</p>
      </turbo-frame>
    </div>
  </div>
</div>

<%# =====================================================
    Datasets section (hidden until user navigates)
    ===================================================== %>
<div id="container-datasets" class="container-main-content hidden">
  <div class="container-section-inner">
    <%= render "datasets" %>
  </div>
</div>

<%# =====================================================
    Documentation section
    ===================================================== %>
<div id="container-documentation" class="container-main-content hidden">
  <div class="container-section-inner">
    <h3 class="placeholder">Documentation</h3>
  </div>
</div>

<%# =====================================================
    Downloads section (hidden until user navigates)
    ===================================================== %>
<div id="container-downloads" class="container-main-content hidden">
  <div class="container-section-inner">
    <%= render "downloads" %>
  </div>
</div>

<%# =====================================================
    PWS Report overlay (hidden, toggled on map click)
    ===================================================== %>
<div id="container-report" class="hidden" data-controller="report" data-report-target="overlay">
  <a href="javascript:void(0);" onclick="window.print()" id="tt-print-report" class="btn-report btn-print-report"><%= image_tag "icon-print.png" %></a>
  <a href="javascript:void(0);" id="tt-close-report" class="btn-report btn-close-report" data-action="click->report#close"><%= image_tag "icon-close.png" %></a>

  <div class="container-report-section-inner">
    <div class="header">
      <div class="header-logo">
        <div class="id-logo">
          <%= image_tag "logo-drinking-water-explorer.png", class: "logo" %>
        </div>
        <div class="id-text">
          <p>Drinking</p>
          <p>Water</p>
          <p>Explorer</p>
        </div>
      </div>
      <div class="header-title">
        <p style="margin-bottom:10px;">Utility Report</p>
        <p><strong>Utility Name: </strong><span data-report-target="utilityName"></span></p>
        <p><strong>System ID: </strong><span data-report-target="systemId"></span></p>
        <p><strong><span class="report-city">City</span>, <span data-report-target="state">State</span></strong></p>
      </div>
    </div>
    <div class="clearfix"></div>
    <div class="container-report-body">
      <turbo-frame id="report-body" data-report-target="frame">
        <%# Report content loaded via Turbo Frame from ReportsController %>
      </turbo-frame>
    </div>
  </div>
</div>

<%# Mobile footer (hidden on desktop) %>
<div class="mobile-footer hide-for-desktop">
  <%= image_tag "EPIC-logo.png" %>
  <% if @last_updated %>
    <p>Last updated on <%= @last_updated.in_time_zone("Eastern Time (US & Canada)").strftime("%m/%d/%Y at %I:%M %p %Z") %></p>
  <% end %>
  <p>(cc) Environmental Policy Innovation Center (EPIC)</p>
</div>

<%# Mobile menu overlay %>
<div id="container-mobile-menu" class="" style="display:none;">
  <div class="container-mobile-menu-inner">
    <p><strong>How to use this tool:</strong></p>
    <p>Search or zoom into the map to see information about public drinking water systems in areas of interest. Use the filters to customize the display.</p>
    <ul>
      <li class="nav-1"><a href="javascript:void(0);" data-section="map" data-action="click->nav#show" class="nav-item nav-1 nav-map active">Explore the Map</a></li>
      <li class="nav-2"><a href="javascript:void(0);" data-section="datasets" data-action="click->nav#show" class="nav-item nav-2 nav-datasets">Datasets</a></li>
      <li class="nav-3"><a href="https://tech-team-data.s3.us-east-1.amazonaws.com/national-dw-tool/public-data-downloads/EPIC's+Drinking+Water+Explorer+Tool+-+Methodology.pdf" target="_blank" class="nav-item nav-3 nav-documentation">Documentation</a></li>
      <li class="nav-4"><a href="javascript:void(0);" data-section="downloads" data-action="click->nav#show" class="nav-item nav-4 nav-downloads">Downloads</a></li>
      <li class="nav-5"><a href="https://github.com/Environmental-Policy-Innovation-Center/national-dw-tool-public" target="_blank" class="nav-item nav-5">Github</a></li>
      <li class="nav-6"><a href="https://docs.google.com/forms/d/e/1FAIpQLSdj-JcAmFNHnyEGoou74kyL_R1YOUtsFG4dKlYl0TWWwkUcrg/viewform" target="_blank" class="nav-item nav-6">Feedback</a></li>
      <li class="nav-7"><a href="mailto:watertool@policyinnovation.org" class="nav-item nav-7">Contact EPIC</a></li>
    </ul>
    <p style="margin:40px 0px 0px 20px;">(<a href="https://creativecommons.org/share-your-work/cclicenses/" target="_blank">cc</a>) Environmental Policy<br/>Center (EPIC)</p>
  </div>
</div>
