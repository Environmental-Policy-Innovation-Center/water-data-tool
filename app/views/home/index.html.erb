<% content_for :head do %>
  <style>
    /* @page at-rules and the body > *:not selector can't be expressed as Tailwind utilities */
    @page {
      margin: 0.5in;
      @top-left    { content: none; }
      @top-center  { content: none; }
      @top-right   { content: none; }
      @bottom-left { content: none; }
      @bottom-center { content: none; }
      @bottom-right {
        content: counter(page) " of " counter(pages);
        font-family: 'Public Sans', Arial, Helvetica, sans-serif;
        font-size: 10px;
        color: #565656;
      }
    }
    @media print {
      body > *:not(#container-report) { display: none !important; }
    }
  </style>
<% end %>

<%# Mobile header %>
<div class="sm:hidden fixed top-0 w-full p-3 bg-white z-[9999] text-center">
  <div class="float-left"><%= icon "water", classes: "w-9 h-auto inline-block" %></div>
  <h1 class="inline-block text-[1.2em] m-0 font-medium pt-1 text-brand-primary">Drinking Water Explorer</h1>
  <div class="float-right">
    <button type="button" id="mobile-menu-toggle" class="mobile-btn closed cursor-pointer p-2.5" aria-expanded="false" aria-label="Toggle navigation menu" data-action="click->nav#toggleMobile">
      <%= icon "mobile-menu", classes: "mm-icon-bars" %>
      <%= icon "close", classes: "mm-icon-x hidden" %>
    </button>
  </div>
</div>

<%# Loading mask — hidden by map_controller once map is ready %>
<div id="loading-mask" class="absolute inset-0 bg-black/60 z-[1002] text-center">
  <p class="pt-[200px] text-2xl text-white">LOADING DATA...</p>
</div>

<%# Active filter tag list (shown above map when filters are applied) %>
<div id="filter-list-container" style="display:none;">
  <small>Active Filters</small>
  <ul id="filter-list">
    <%# Filled dynamically by filter_controller %>
  </ul>
</div>

<%# Left sidebar navigation %>
<%= render "sidebar" %>

<%# =====================================================
    Map view (default section)
    ===================================================== %>
<div id="container-map" class="container-main-content group/map bg-[#ccc] fixed inset-x-0 top-[68px] bottom-[70px] overflow-y-auto sm:absolute sm:inset-0 sm:overflow-visible"
     data-controller="map filter filter-menu"
     data-map-tile-url-value="/tiles/{z}/{x}/{y}">

  <%# Filter tab bar — filter-layout controller lives here so its ResizeObserver measures the
      filter bar's actual usable width (viewport − sidebar offset), not the full container width. %>
  <div id="container-map-ui-top" class="block absolute top-0 left-0 right-0 z-[10] sm:z-[5] pointer-events-none"
       data-controller="filter-layout">
    <ul id="filter-tabs" role="group" aria-label="Water System Filters" class="m-0 flex list-none flex-nowrap items-start justify-end gap-1.5 pt-3 pl-5 pr-5 pointer-events-none">
      <%# Table search — visible only in table mode, anchored to the left %>
      <li class="hidden group-[.table-mode]/map:flex items-center mr-auto pointer-events-auto"
          data-controller="table-search">
        <div class="relative">
          <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-neutral-500">
            <%= icon "search", classes: "h-4 w-4" %>
          </span>
          <input type="search"
                 data-table-search-target="input"
                 data-action="input->table-search#search"
                 placeholder="Search table…"
                 autocomplete="off"
                 aria-label="Search public water utilities"
                 class="h-10 w-36 md:w-52 rounded-full border border-neutral-400 bg-white pl-9 pr-4 text-sm text-neutral-900 placeholder:text-neutral-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 motion-reduce:transition-none">
        </div>
      </li>

      <% FilterLayout.menus.each do |menu_key, menu| %>
        <%= render UI::FilterMenuTabComponent.new(menu_key: menu_key, label: menu[:label], mobile_label: menu[:mobile_label]) %>
      <% end %>
    </ul>
  </div>

  <%# Filter dropdown menus %>
  <%= render "filter_menus" %>

  <%# Mapbox GL JS canvas %>
  <div id="map" class="w-full h-full"></div>

  <%# Map region shortcuts (48 / AK / HI / territories) — below +/− zoom controls %>
  <div id="container-region-nav" class="hidden sm:block absolute left-[10px] top-[135px] z-[1] group-[.table-mode]/map:hidden">
    <%= render UI::MapRegionShortcutButtonComponent.new(label: "48", aria_label: "Zoom to 48 states", map_action: "zoom48") %>
    <%= render UI::MapRegionShortcutButtonComponent.new(label: "AK", aria_label: "Zoom to Alaska", map_action: "zoomAk") %>
    <%= render UI::MapRegionShortcutButtonComponent.new(label: "HI", aria_label: "Zoom to Hawaii", map_action: "zoomHi") %>
    <hr class="border-0 border-t border-[#ddd] mt-1.5 mb-0.5 mx-0.5">
    <%= render UI::MapRegionShortcutButtonComponent.new(label: "PR", aria_label: "Zoom to Puerto Rico", map_action: "zoomPr") %>
    <%= render UI::MapRegionShortcutButtonComponent.new(label: "GU", aria_label: "Zoom to Guam", map_action: "zoomGu") %>
    <%= render UI::MapRegionShortcutButtonComponent.new(label: "MP", aria_label: "Zoom to Northern Mariana Islands", map_action: "zoomMp") %>
  </div>

  <%# Intro tooltip — bottom right of map canvas %>
  <div id="container-map-content-bottom" class="group-[.table-mode]/map:hidden group-[.section-mode]/map:hidden">
    <div id="container-how-to-use" class="hidden absolute left-4 right-[74px] bottom-12 z-[9] sm:left-auto sm:right-5 sm:bottom-[100px] sm:max-w-[310px] sm:block bg-white border border-neutral-400 rounded-[20px] py-2.5 px-5">
      <p class="text-[1.2em] leading-[1.4] m-0"><strong>How to use this tool:</strong></p>
      <p class="text-[1em] leading-[1.4] my-2.5 mx-0">Search or zoom into the map to see information about public drinking water systems in areas of interest. Use the filters to customize the display.</p>
    </div>
  </div>

  <turbo-frame id="stats-bar"></turbo-frame>

  <%# Mobile floating action buttons — filter and stats %>
  <div id="container-mobile-map-actions" class="sm:hidden absolute right-[10px] bottom-12 z-[10] flex flex-col gap-3">
    <div class="group-[.table-mode]/map:hidden group-[.section-mode]/map:hidden">
      <%= render UI::CircleButtonComponent.new(
            id: "btn-mobile-filter",
            aria_label: "Toggle map filters",
            data_action: "click->nav#toggleMobileFilterPanel",
            classes: "w-12! h-12! shadow-sm data-[active]:bg-brand-primary data-[active]:border-brand-primary data-[active]:text-white"
          ) do %>
        <%= icon "filter", classes: "w-6 h-6" %>
      <% end %>
    </div>
    <div class="group-[.table-mode]/map:hidden group-[.section-mode]/map:hidden">
      <%= render UI::CircleButtonComponent.new(
            id: "btn-mobile-stats",
            aria_label: "Toggle statistics panel",
            data_action: "click->nav#toggleMobileStats",
            classes: "w-12! h-12! shadow-sm data-[active]:bg-brand-primary data-[active]:border-brand-primary data-[active]:text-white"
          ) do %>
        <%= icon "info", classes: "w-6 h-6" %>
      <% end %>
    </div>
  </div>

  <%# Map click popup: map_controller.js. Report overlay below is map-only (not used for direct URL visits). %>
  <%= render "map_popup_template" %>

  <%# Map/Table view toggle — bottom right of map canvas %>
  <div id="container-map-ui-bottom"
       class="hidden sm:block sm:absolute sm:right-5 sm:bottom-[42px] sm:z-[999] group-[.section-mode]/map:hidden">
    <ul class="m-0 flex list-none flex-nowrap items-center gap-1.5 pt-1.5 pl-5">
      <li class="relative shrink-0">
        <button type="button"
           data-section="map"
           class="nav-item nav-map-toggle active relative inline-flex items-center whitespace-nowrap rounded-full border border-neutral-400 bg-[#fdfefb] px-3 py-2 pl-8 text-base font-normal leading-none text-neutral-700 cursor-pointer [&.active]:bg-[#989898] [&.active]:text-white"
           data-action="click->nav#show">
          <%= icon "map", classes: "pointer-events-none absolute left-2.5 top-1/2 size-[17px] -translate-y-1/2" %>
          Map
        </button>
      </li>
      <li class="relative shrink-0">
        <button type="button"
           data-section="table"
           class="nav-item nav-table relative inline-flex items-center whitespace-nowrap rounded-full border border-neutral-400 bg-[#fdfefb] px-3 py-2 pl-8 text-base font-normal leading-none text-neutral-700 cursor-pointer [&.active]:bg-[#989898] [&.active]:text-white"
           data-action="click->nav#show">
          <%= icon "table", classes: "pointer-events-none absolute left-2.5 top-1/2 size-[17px] -translate-y-1/2" %>
          Table
        </button>
      </li>
    </ul>
  </div>

  <%# =====================================================
      Table view — lives inside container-map so the filter
      bar stays visible when the user switches to it.
      Shown/hidden by nav_controller.js#show via classList.
      ===================================================== %>
  <div id="container-table" class="hidden max-md:!hidden absolute bg-white z-[3] top-3 right-4 bottom-8 rounded-xl shadow-lg overflow-hidden">
    <div class="flex min-h-0 flex-1 flex-col px-5 pt-[52px]"
         data-controller="row-selection">
      <div class="flex items-center justify-between gap-4 py-5">
        <%# Title + export controls: grouped left %>
        <div class="flex min-w-0 flex-wrap items-center gap-3">
          <p class="m-0 shrink-0 p-0 text-base">
            <strong>Public Water Utilities <span class="geo-filter"></span></strong>
          </p>
          <div class="flex shrink-0 flex-nowrap items-center gap-3"
               data-controller="export"
               data-export-url-value="<%= export_path %>">
            <button type="button"
               class="relative inline-flex cursor-pointer flex-nowrap items-center whitespace-nowrap rounded-full border border-neutral-400 bg-brand-action px-3 py-1.5 pl-9 text-sm font-normal leading-none text-white <%= focus_ring_classes %>"
               data-row-selection-target="exportButton"
               data-action="click->export#download">
              <%= icon "downloads", classes: "pointer-events-none absolute left-2.5 top-1/2 size-4 -translate-y-1/2" %>
              Export Selection
              <span data-row-selection-target="countBadge"
                    class="hidden ml-1.5 min-w-[2rem] rounded-full bg-white/25 px-1.5 py-0.5 text-center text-xs leading-none tabular-nums"
                    aria-live="polite"
                    aria-label="selected rows count"></span>
            </button>
            <span class="inline-flex flex-nowrap items-center gap-3">
              <span class="inline-flex items-center gap-1.5 whitespace-nowrap">
                <input type="radio" name="file-type" id="file-csv" value="csv" checked
                       data-export-target="format"
                       class="m-0">
                <label for="file-csv">.csv</label>
              </span>
              <span class="inline-flex items-center gap-1.5 whitespace-nowrap">
                <input type="radio" name="file-type" id="file-geojson" value="geojson"
                       class="file-geojson m-0" data-export-target="format">
                <label for="file-geojson" class="file-geojson">.geojson</label>
                <span class="relative inline-block cursor-default"
                      data-controller="tooltip"
                      data-tooltip-text-value="<%= exports_tooltips['geojson'] %>"
                      data-action="mouseenter->tooltip#show mouseleave->tooltip#hide">
                  <%= icon "info", classes: "h-3.5 w-3.5 inline align-middle" %>
                </span>
              </span>
            </span>
          </div>
        </div>

        <%# Manage Columns: far right with fixed-position disclosure panel %>
        <div class="shrink-0" data-controller="manage-columns">
          <button type="button"
                  class="inline-flex min-h-11 cursor-pointer items-center gap-1.5 font-bold text-brand-primary hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 motion-reduce:transition-none"
                  data-manage-columns-target="button"
                  data-action="click->manage-columns#toggle"
                  aria-expanded="false"
                  aria-controls="manage-columns-panel">
            Manage Columns
            <%= icon "columns", classes: "size-4" %>
          </button>
          <div id="manage-columns-panel"
               data-manage-columns-target="dropdown"
               class="hidden fixed w-80 flex-col overflow-hidden rounded-xl border border-neutral-200 bg-white shadow-xl z-[100]">
            <form data-manage-columns-target="form"
                  data-action="submit->manage-columns#serializeCols"
                  data-turbo="false"
                  class="flex flex-col flex-1 min-h-0">

              <div class="flex shrink-0 items-center justify-start pl-3 pr-4 pt-2 pb-1">
                <%= render UI::CircleButtonComponent.new(
                      id: "manage-columns-toggle-all",
                      aria_label: "Toggle all columns",
                      data_action: "click->manage-columns#toggleAllColumns",
                      label: "Deselect all",
                      label_position: :right
                    ) do %>
                  <span id="manage-columns-toggle-all-icon-on">
                    <%= icon "checkbox-circle-on", classes: "size-4 text-neutral-900" %>
                  </span>
                  <span id="manage-columns-toggle-all-icon-off" class="hidden">
                    <%= icon "checkbox-circle-off", classes: "size-4 text-neutral-700" %>
                  </span>
                <% end %>
              </div>
              <ul class="m-0 flex-1 min-h-0 list-none overflow-y-auto px-2 pb-1 pt-1"
                  data-manage-columns-target="columnList"
                  aria-label="Table columns">
                <%= render "home/manage_columns_list",
                      panel_groups: @panel_groups,
                      visible_col_keys: @visible_col_keys %>
              </ul>
              <template data-manage-columns-target="defaultTemplate">
                <%= render "home/manage_columns_list",
                      panel_groups: ColumnRegistry.panel_groups(col_keys: nil),
                      force_all_checked: true %>
              </template>
              <div class="shrink-0 border-t border-neutral-100 bg-white pb-2.5 pt-1 text-center"
                   role="group"
                   aria-label="Column actions">
                <button type="button"
                        data-action="click->manage-columns#reset"
                        class="inline-block cursor-pointer rounded-full border border-neutral-400 bg-white mx-2 my-1.5 min-h-11 px-7 py-2 text-sm text-neutral-800 md:hover:bg-neutral-200 md:hover:text-black focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 motion-reduce:transition-none">
                  Reset
                </button>
                <button type="submit"
                        class="inline-block cursor-pointer rounded-full border border-brand-primary bg-brand-primary mx-2 my-1.5 min-h-11 px-7 py-2 text-sm text-white md:hover:brightness-110 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 motion-reduce:transition-none">
                  Show Columns
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <%# Table loaded via Turbo Frame — filter_controller sets src on table:show %>
      <turbo-frame id="data-table"
                   class="flex min-h-0 flex-1 flex-col"
                   aria-live="polite"
                   aria-label="Public water systems table"
                   data-controller="table-frame"
                   data-turbo-prefetch="false">
        <p class="px-3 py-8 text-center text-gray-400 text-sm">Loading data table…</p>
      </turbo-frame>
    </div>
  </div>
</div>

<%# =====================================================
    Datasets section (hidden until user navigates)
    ===================================================== %>
<div id="container-datasets" class="container-main-content hidden fixed top-[60px] bottom-[50px] left-0 right-0 bg-white rounded-xl shadow-lg overflow-hidden sm:absolute sm:top-3 sm:bottom-8">
  <div class="h-full overflow-y-auto">
    <%= render "datasets" %>
  </div>
</div>

<%# =====================================================
    Documentation section
    ===================================================== %>
<div id="container-documentation" class="container-main-content hidden fixed top-[60px] bottom-[50px] left-0 right-0 bg-white rounded-xl shadow-lg overflow-hidden sm:absolute sm:top-3 sm:bottom-8">
  <div class="h-full overflow-y-auto px-5 py-5">
    <h3 class="m-0 text-base font-semibold">Documentation</h3>
  </div>
</div>

<%# =====================================================
    Downloads section (hidden until user navigates)
    ===================================================== %>
<div id="container-downloads" class="container-main-content hidden fixed top-[60px] bottom-[50px] left-0 right-0 bg-white rounded-xl shadow-lg overflow-hidden sm:absolute sm:top-3 sm:bottom-8">
  <div class="h-full overflow-y-auto">
    <%= render "downloads" %>
  </div>
</div>

<%# =====================================================
    Map-only shell: normal "View Full Report" click from popup (see map_controller.js).
    User stays on /; print + close (X). Not used when opening the report URL directly.
    ===================================================== %>
<div id="container-report"
     class="hidden fixed inset-0 z-[9999] bg-white overflow-y-auto print:static print:h-auto print:overflow-visible"
     role="dialog"
     aria-modal="true"
     aria-label="Utility report"
     data-controller="report"
     data-report-target="overlay">
  <%= render UI::CircleButtonComponent.new(
        id: "tt-print-report",
        aria_label: "Print report",
        data_action: "click->report#print",
        classes: "fixed top-[30px] right-20 print:hidden"
      ) do %>
    <%= icon "print", classes: "h-4 w-4" %>
  <% end %>
  <%= render UI::CircleButtonComponent.new(
        id: "tt-close-report",
        aria_label: "Close report",
        data_action: "click->report#close",
        classes: "fixed top-[30px] right-5 print:hidden"
      ) do %><%= icon "close", classes: "h-4 w-4" %><% end %>

  <div class="mx-auto max-w-[1200px] border border-[#eee] bg-white p-4 mt-4 mb-8 sm:p-10 sm:mt-[30px] sm:mb-[50px] print:border-0 print:p-0 print:mt-0 print:mb-0">
    <%# Turbo Frame target: report HTML loaded here on in-app click (Turbo.visit from map_controller). %>
    <turbo-frame id="report-body" data-report-target="frame">
    </turbo-frame>
  </div>
</div>

<%# Mobile footer %>
<div class="sm:hidden fixed bottom-0 w-full pb-[10px] px-[10px] bg-brand-primary z-[99999] text-center">
  <div class="flex justify-center -mt-5">
    <div class="bg-white rounded-full p-0.25">
      <%= icon "epic", classes: "block w-9 h-auto" %>
    </div>
  </div>
  <% if @last_updated %>
    <p class="text-white m-0 text-[0.9em]">Latest data update on <%= @last_updated.in_time_zone("Eastern Time (US & Canada)").strftime("%m/%d/%Y at %I:%M %p %Z") %></p>
  <% end %>
  <p class="text-white m-0 text-[0.9em]">(<%= render UI::ExternalLinkComponent.new(url: "https://creativecommons.org/share-your-work/cclicenses/", classes: "text-white") do %><span class="sr-only">Creative Commons license</span><span aria-hidden="true">cc</span><% end %>) Environmental Policy Innovation Center (EPIC)</p>
</div>

<%# Mobile menu overlay %>
<div id="container-mobile-menu" class="hidden fixed inset-0 bg-white z-[999] overflow-y-scroll">
  <div class="flex flex-col min-h-full pt-[60px] pb-36 px-5">
    <p class="pt-6 pb-2"><strong>How to use this tool:</strong></p>
    <p class="pb-6">Search or zoom into the map to see information about public drinking water systems in areas of interest. Use the filters to customize the display.</p>
    <ul class="list-none m-0 p-0">
      <%= render "core_section_nav", list_item_class: "px-5", include_table: false %>
      <li class="px-5">
        <%= render UI::NavItemComponent.new(
          label: "Github",
          icon_name: "github",
          href: "https://github.com/Environmental-Policy-Innovation-Center/national-dw-tool-public",
          external: true
        ) %>
      </li>
      <li class="px-5">
        <%= render UI::NavItemComponent.new(
          label: "Feedback",
          icon_name: "feedback",
          href: "https://docs.google.com/forms/d/e/1FAIpQLSdj-JcAmFNHnyEGoou74kyL_R1YOUtsFG4dKlYl0TWWwkUcrg/viewform",
          external: true
        ) %>
      </li>
      <li class="px-5">
        <%= render UI::NavItemComponent.new(
          label: "Contact EPIC",
          icon_name: "email",
          href: "mailto:watertool@policyinnovation.org"
        ) %>
      </li>
    </ul>
  </div>
</div>
