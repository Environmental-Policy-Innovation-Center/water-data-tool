<%# Mobile header (hidden on desktop via CSS) %>
<div class="mobile-header hide-for-desktop">
  <div class="m-header-left"><%= icon "water", classes: "w-9 h-auto inline-block" %></div>
  <h1>Drinking Water Explorer</h1>
  <div class="m-header-right">
    <button type="button" id="mobile-menu-toggle" class="mobile-btn closed cursor-pointer" aria-expanded="false" aria-label="Toggle navigation menu" data-action="click->nav#toggleMobile">
      <%= icon "mobile-menu", classes: "mm-icon-bars" %>
      <%= icon "close", classes: "mm-icon-x hidden" %>
    </button>
  </div>
</div>

<%# Loading mask — hidden by map_controller once map is ready %>
<div id="loading-mask">
  <p>LOADING DATA...</p>
</div>

<%# Active filter tag list (shown above map when filters are applied) %>
<div id="filter-list-container" style="display:none;">
  <small>Active Filters</small>
  <ul id="filter-list">
    <%# Filled dynamically by filter_controller %>
  </ul>
</div>

<%# Canonical filter keys from config/filters.yml (FilterRegistry) — embedded JSON for filter_controller %>
<%= render "filter_registry_config" %>

<%# Left sidebar navigation %>
<%= render "sidebar" %>

<%# =====================================================
    Map view (default section)
    ===================================================== %>
<div id="container-map" class="container-main-content w-full absolute left-0"
     data-controller="map filter filter-menu"
     data-map-tile-url-value="/tiles/{z}/{x}/{y}">

  <%# Filter tab bar — filter-layout controller lives here so its ResizeObserver measures the
      filter bar's actual usable width (viewport − sidebar offset), not the full container width. %>
  <div id="container-map-ui-top" class="max-[640px]:hidden min-[640px]:absolute min-[640px]:top-0 min-[640px]:left-0 min-[640px]:right-0 min-[640px]:z-[5]"
       data-controller="filter-layout">
    <ul id="filter-tabs" role="group" aria-label="Water System Filters" class="m-0 flex list-none flex-nowrap items-center justify-end gap-1.5 pt-3 pl-5 pr-5">
      <%= render UI::FilterTabComponent.new(menu_id: 1, label: "Source", li_id: "source-filter-button") %>
      <%= render UI::FilterTabComponent.new(menu_id: 2, label: "Attributes", li_id: "attributes-filter-button") %>
      <%= render UI::FilterTabComponent.new(menu_id: 3, label: "Boundaries", li_id: "boundaries-filter-button") %>
      <%= render UI::FilterTabComponent.new(menu_id: 4, label: "Compliance", li_id: "compliance-filter-button") %>
      <%= render UI::FilterTabComponent.new(menu_id: 5, label: "Population", li_id: "population-filter-button") %>
      <%= render UI::FilterTabComponent.new(menu_id: 10, label: "More", li_id: "more-filter-button") %>
    </ul>
  </div>

  <%# Filter dropdown menus %>
  <%= render "filter_menus" %>

  <%# Mapbox GL JS canvas %>
  <div id="map"></div>

  <%# Map region shortcuts (48 / AK / HI / territories) — below +/− zoom controls %>
  <div id="container-region-nav" class="absolute left-0 top-[135px] z-[1] max-[640px]:hidden hide-for-table">
    <%= render UI::MapRegionShortcutButtonComponent.new(label: "48", aria_label: "Zoom to 48 states", map_action: "zoom48", territory: false) %>
    <%= render UI::MapRegionShortcutButtonComponent.new(label: "AK", aria_label: "Zoom to Alaska", map_action: "zoomAk", territory: false) %>
    <%= render UI::MapRegionShortcutButtonComponent.new(label: "HI", aria_label: "Zoom to Hawaii", map_action: "zoomHi", territory: false) %>
    <hr class="border-0 border-t border-[#ddd] mt-1.5 mb-0.5 mx-0.5">
    <%= render UI::MapRegionShortcutButtonComponent.new(label: "PR", aria_label: "Zoom to Puerto Rico (territory)", map_action: "zoomPr", territory: true) %>
    <%= render UI::MapRegionShortcutButtonComponent.new(label: "GU", aria_label: "Zoom to Guam (territory)", map_action: "zoomGu", territory: true) %>
    <%= render UI::MapRegionShortcutButtonComponent.new(label: "MP", aria_label: "Zoom to Northern Mariana Islands (territory)", map_action: "zoomMp", territory: true) %>
  </div>

  <%# Intro tooltip — bottom right of map canvas %>
  <div id="container-map-content-bottom" class="hide-for-table">
    <div class="map-content-wrapper map-content-wrapper-desktop map-content-intro hide-for-table">
      <div class="intro-content">
        <p><strong>How to use this tool:</strong></p>
        <p>Search or zoom into the map to see information about public drinking water systems in areas of interest. Use the filters to customize the display.</p>
      </div>
    </div>
  </div>

  <turbo-frame id="stats-bar"></turbo-frame>

  <%# Detail data loaded via Mapbox popup on map click;
      full report loaded into report-body Turbo Frame below %>

  <%# Map/Table view toggle — bottom right of map canvas %>
  <div id="container-map-ui-bottom"
       class="hide-for-mobile hide-for-table absolute right-5 bottom-[30px] z-[999]">
    <ul class="m-0 flex list-none flex-nowrap items-center gap-1.5 pt-1.5 pl-5">
      <li class="relative shrink-0">
        <button type="button"
           data-section="map"
           class="nav-item nav-map-toggle active relative inline-flex items-center whitespace-nowrap rounded-full border border-neutral-400 bg-[#fdfefb] px-3 py-2 pl-8 text-base font-normal leading-none text-neutral-700 cursor-pointer [&.active]:bg-[#989898] [&.active]:text-white"
           data-action="click->nav#show">
          <%= icon "map", classes: "pointer-events-none absolute left-2.5 top-1/2 size-[17px] -translate-y-1/2" %>
          Map
        </button>
      </li>
      <li class="relative shrink-0">
        <button type="button"
           data-section="table"
           class="nav-item nav-table relative inline-flex items-center whitespace-nowrap rounded-full border border-neutral-400 bg-[#fdfefb] px-3 py-2 pl-8 text-base font-normal leading-none text-neutral-700 cursor-pointer [&.active]:bg-[#989898] [&.active]:text-white"
           data-action="click->nav#show">
          <%= icon "table", classes: "pointer-events-none absolute left-2.5 top-1/2 size-[17px] -translate-y-1/2" %>
          Table
        </button>
      </li>
    </ul>
  </div>

  <%# =====================================================
      Table view — lives inside container-map so the filter
      bar stays visible when the user switches to it.
      Shown/hidden via the .table-mode class on container-map.
      ===================================================== %>
  <div id="container-table">
    <div class="container-section-inner flex min-h-0 flex-1 flex-col px-5 pb-0 pt-5">
      <div class="mt-[60px] flex min-w-0 flex-col gap-4 overflow-hidden py-6 sm:flex-row sm:items-center sm:justify-between sm:gap-6">
        <div class="min-w-0 shrink">
          <p class="m-0 p-0 text-base">
            <strong>Public Water Utilities <span class="geo-filter"></span></strong>
          </p>
        </div>
        <div class="flex min-w-0 shrink-0 flex-nowrap items-center justify-end gap-3 sm:gap-4"
             data-controller="export">
          <a href="#"
             class="relative inline-flex flex-nowrap items-center whitespace-nowrap rounded-full border border-neutral-400 bg-[#67a25e] px-3 py-1.5 pl-9 text-sm font-normal leading-none text-white no-underline"
             data-action="click->export#download">
            <%= icon "downloads",
                  classes: "pointer-events-none absolute left-2.5 top-1/2 size-4 -translate-y-1/2" %>
            Export
          </a>
          <span class="inline-flex flex-nowrap items-center gap-3">
            <span class="inline-flex items-center gap-1.5 whitespace-nowrap">
              <input type="radio" name="file-type" id="file-csv" value="csv" checked
                     data-export-target="format"
                     class="m-0" />
              <label for="file-csv">.csv</label>
            </span>
            <span class="inline-flex items-center gap-1.5 whitespace-nowrap">
              <input type="radio" name="file-type" id="file-geojson" value="geojson"
                     class="file-geojson m-0" data-export-target="format" />
              <label for="file-geojson" class="file-geojson">.geojson</label>
            </span>
          </span>
        </div>
      </div>

      <%# Table loaded via Turbo Frame — filter_controller sets src on table:show %>
      <turbo-frame id="data-table"
                   class="flex min-h-0 flex-1 flex-col"
                   aria-live="polite"
                   aria-label="Public water systems table"
                   data-controller="table-frame">
        <p class="px-3 py-8 text-center text-gray-400 text-sm">Loading data table…</p>
      </turbo-frame>
    </div>
  </div>
</div>

<%# =====================================================
    Datasets section (hidden until user navigates)
    ===================================================== %>
<div id="container-datasets" class="container-main-content w-full absolute left-0 hidden">
  <div class="container-section-inner">
    <%= render "datasets" %>
  </div>
</div>

<%# =====================================================
    Documentation section
    ===================================================== %>
<div id="container-documentation" class="container-main-content w-full absolute left-0 hidden">
  <div class="container-section-inner">
    <h3 class="placeholder">Documentation</h3>
  </div>
</div>

<%# =====================================================
    Downloads section (hidden until user navigates)
    ===================================================== %>
<div id="container-downloads" class="container-main-content w-full absolute left-0 hidden">
  <div class="container-section-inner">
    <%= render "downloads" %>
  </div>
</div>

<%# =====================================================
    PWS Report overlay (hidden, toggled on map click)
    ===================================================== %>
<div id="container-report" class="hidden" data-controller="report" data-report-target="overlay">
  <button type="button" onclick="window.print()" id="tt-print-report" class="btn-report btn-print-report cursor-pointer" aria-label="Print report"><%= icon "print", classes: "h-5 w-5" %></button>
  <button type="button" id="tt-close-report" class="btn-report btn-close-report cursor-pointer" aria-label="Close report" data-action="click->report#close"><%= icon "close" %></button>

  <div class="container-report-section-inner">
    <div class="container-report-body mt-0!">
      <turbo-frame id="report-body" data-report-target="frame">
        <%# Report content loaded via Turbo Frame from ReportsController %>
      </turbo-frame>
    </div>
  </div>
</div>

<%# Mobile footer (hidden on desktop) %>
<div class="mobile-footer hide-for-desktop">
  <%= icon "epic", classes: "w-9 h-auto" %>
  <% if @last_updated %>
    <p>Last updated on <%= @last_updated.in_time_zone("Eastern Time (US & Canada)").strftime("%m/%d/%Y at %I:%M %p %Z") %></p>
  <% end %>
  <p>(cc) Environmental Policy Innovation Center (EPIC)</p>
</div>

<%# Mobile menu overlay %>
<div id="container-mobile-menu" class="" style="display:none;">
  <div class="container-mobile-menu-inner flex flex-col min-h-full">
    <p class="pt-6 pb-2"><strong>How to use this tool:</strong></p>
    <p class="pb-6">Search or zoom into the map to see information about public drinking water systems in areas of interest. Use the filters to customize the display.</p>
    <ul>
      <li class="nav-1"><button type="button" data-section="map" data-action="click->nav#show" class="nav-item nav-1 nav-map active flex items-center gap-3 px-4 py-2.5 bg-white text-neutral-900 cursor-pointer rounded-full border border-neutral-400 my-2 mx-5 hover:bg-neutral-200 hover:text-black [&.active]:bg-brand-primary [&.active]:border-brand-primary [&.active]:text-white"><%= icon "explore", classes: "h-[18px] w-[18px] shrink-0" %>Explore the Map</button></li>
      <li class="nav-2"><button type="button" data-section="datasets" data-action="click->nav#show" class="nav-item nav-2 nav-datasets flex items-center gap-3 px-4 py-2.5 bg-white text-neutral-900 cursor-pointer rounded-full border border-neutral-400 my-2 mx-5 hover:bg-neutral-200 hover:text-black [&.active]:bg-brand-primary [&.active]:border-brand-primary [&.active]:text-white"><%= icon "data", classes: "h-[18px] w-[18px] shrink-0" %>Datasets</button></li>
      <li class="nav-3"><a href="https://tech-team-data.s3.us-east-1.amazonaws.com/national-dw-tool/public-data-downloads/EPIC's+Drinking+Water+Explorer+Tool+-+Methodology.pdf" target="_blank" rel="noopener noreferrer" title="Opens in new tab" class="nav-item nav-3 nav-documentation flex items-center gap-3 px-4 py-2.5 bg-white text-neutral-900 no-underline rounded-full border border-neutral-400 my-2 mx-5 hover:bg-neutral-200 hover:text-black [&.active]:bg-brand-primary [&.active]:border-brand-primary [&.active]:text-white"><%= icon "documentation", classes: "h-[18px] w-[18px] shrink-0" %><span class="flex-1">Documentation</span><%= icon "external-link", classes: "inline ml-1 shrink-0" %><span class="sr-only">(opens in new tab)</span></a></li>
      <li class="nav-4"><button type="button" data-section="downloads" data-action="click->nav#show" class="nav-item nav-4 nav-downloads flex items-center gap-3 px-4 py-2.5 bg-white text-neutral-900 cursor-pointer rounded-full border border-neutral-400 my-2 mx-5 hover:bg-neutral-200 hover:text-black [&.active]:bg-brand-primary [&.active]:border-brand-primary [&.active]:text-white"><%= icon "downloads", classes: "h-[18px] w-[18px] shrink-0" %>Downloads</button></li>
      <li class="nav-5"><a href="https://github.com/Environmental-Policy-Innovation-Center/national-dw-tool-public" target="_blank" rel="noopener noreferrer" title="Opens in new tab" class="nav-item nav-5 flex items-center gap-3 px-4 py-2.5 bg-white text-neutral-900 no-underline rounded-full border border-neutral-400 my-2 mx-5 hover:bg-neutral-200 hover:text-black"><%= icon "github", classes: "h-[18px] w-[18px] shrink-0" %><span class="flex-1">Github</span><%= icon "external-link", classes: "inline ml-1 shrink-0" %><span class="sr-only">(opens in new tab)</span></a></li>
      <li class="nav-6"><a href="https://docs.google.com/forms/d/e/1FAIpQLSdj-JcAmFNHnyEGoou74kyL_R1YOUtsFG4dKlYl0TWWwkUcrg/viewform" target="_blank" rel="noopener noreferrer" title="Opens in new tab" class="nav-item nav-6 flex items-center gap-3 px-4 py-2.5 bg-white text-neutral-900 no-underline rounded-full border border-neutral-400 my-2 mx-5 hover:bg-neutral-200 hover:text-black"><%= icon "feedback", classes: "h-[18px] w-[18px] shrink-0" %><span class="flex-1">Feedback</span><%= icon "external-link", classes: "inline ml-1 shrink-0" %><span class="sr-only">(opens in new tab)</span></a></li>
      <li class="nav-7"><a href="mailto:watertool@policyinnovation.org" class="nav-item nav-7 flex items-center gap-3 px-4 py-2.5 bg-white text-neutral-900 no-underline rounded-full border border-neutral-400 my-2 mx-5 hover:bg-neutral-200 hover:text-black"><%= icon "email", classes: "h-[18px] w-[18px] shrink-0" %>Contact EPIC</a></li>
    </ul>
    <p class="mt-auto px-5 pt-8 pb-4 text-sm">(<a href="https://creativecommons.org/share-your-work/cclicenses/" target="_blank" rel="noopener noreferrer">cc</a>) Environmental Policy Innovation Center (EPIC)</p>
  </div>
</div>
