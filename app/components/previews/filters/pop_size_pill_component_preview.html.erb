<div class="flex m-4">
  <%= render Filters::PopSizePillComponent.new(id: "preview-pop-very-small", label: "Very small",  sublabel: "500 or less",     pop_number: 1, position: :first) %>
  <%= render Filters::PopSizePillComponent.new(id: "preview-pop-small",      label: "Small",       sublabel: "501 - 3,300",     pop_number: 2) %>
  <%= render Filters::PopSizePillComponent.new(id: "preview-pop-medium",     label: "Medium",      sublabel: "3,301 - 10,000",  pop_number: 3) %>
  <%= render Filters::PopSizePillComponent.new(id: "preview-pop-large",      label: "Large",       sublabel: "10,001 - 100,000", pop_number: 4) %>
  <%= render Filters::PopSizePillComponent.new(id: "preview-pop-very-large", label: "Very large",  sublabel: "100,000+",        pop_number: 5, position: :last) %>
</div>
