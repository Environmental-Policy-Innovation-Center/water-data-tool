<div class="report-section my-6">
  <% if @column_labels %>
    <div class="flex items-baseline mb-2">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500 w-1/2"><%= @title %></h3>
      <div class="flex w-1/2" aria-hidden="true">
        <% @column_labels.each do |col| %>
          <span class="flex-1 text-left text-xs font-semibold text-gray-500"><%= col %></span>
        <% end %>
      </div>
    </div>
  <% else %>
    <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500 mb-2"><%= @title %></h3>
  <% end %>
  <% if !@data_available %>
    <p class="text-sm text-gray-400 italic">Data not available</p>
  <% elsif rows? %>
    <table class="w-full text-sm">
      <% @rows.each do |row| %>
        <tr class="border-b border-gray-100 last:border-0">
          <td class="py-1.5 pr-4 text-gray-500 w-1/2"><%= row[:label] %></td>
          <td class="py-1.5 font-medium text-gray-800"><%= row[:value] %></td>
        </tr>
      <% end %>
    </table>
  <% else %>
    <%= content %>
  <% end %>
</div>
