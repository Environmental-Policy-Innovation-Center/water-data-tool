<h3 class="<%= heading_classes %>">
  <%= @label %>
  <% if tooltip? %>
    <span class="relative ml-1 inline-flex items-center align-middle cursor-default"
          data-controller="tooltip"
          data-tooltip-text-value="<%= @tooltip_text %>"
          data-action="mouseenter->tooltip#show mouseleave->tooltip#hide">
      <%= icon "info", classes: "h-3.5 w-3.5 inline align-middle" %>
    </span>
  <% end %>
</h3>
<%= content %>
