<li class="flex items-center gap-2 rounded px-2 py-1.5">
  <span class="size-3 shrink-0" aria-hidden="true"></span>
  <span class="flex-1 text-sm text-neutral-400"><%= @col.label %></span>
  <input type="checkbox" checked disabled
         aria-label="Show <%= @col.label %> column (always visible)"
         class="size-4 cursor-not-allowed rounded opacity-40">
</li>
